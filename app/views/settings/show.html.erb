<div class="mx-auto max-w-6xl">
  <%= render "shared/back_link", path: episodes_path, text: "Back to Episodes" %>
  <%= render "shared/page_header", title: "Settings" %>

  <div class="lg:grid lg:grid-cols-[12rem_1fr] lg:gap-x-12">
    <%# Left-rail nav (desktop) %>
    <nav class="mb-8 hidden lg:sticky lg:top-6 lg:mb-0 lg:block lg:self-start" aria-label="Settings sections">
      <ul role="list" class="space-y-1 text-sm">
        <li><a href="#voice" class="block rounded-md px-3 py-2 text-mist-700 hover:bg-mist-950/5 hover:text-mist-950 dark:text-mist-300 dark:hover:bg-white/5 dark:hover:text-white">Voice</a></li>
        <% if Current.user.premium? || @subscription.present? %>
          <li><a href="#billing" class="block rounded-md px-3 py-2 text-mist-700 hover:bg-mist-950/5 hover:text-mist-950 dark:text-mist-300 dark:hover:bg-white/5 dark:hover:text-white">Billing</a></li>
        <% end %>
        <li><a href="#extension" class="block rounded-md px-3 py-2 text-mist-700 hover:bg-mist-950/5 hover:text-mist-950 dark:text-mist-300 dark:hover:bg-white/5 dark:hover:text-white">Browser Extension</a></li>
        <li><a href="#api-tokens" class="block rounded-md px-3 py-2 text-mist-700 hover:bg-mist-950/5 hover:text-mist-950 dark:text-mist-300 dark:hover:bg-white/5 dark:hover:text-white">API Tokens</a></li>
        <li><a href="#connected-apps" class="block rounded-md px-3 py-2 text-mist-700 hover:bg-mist-950/5 hover:text-mist-950 dark:text-mist-300 dark:hover:bg-white/5 dark:hover:text-white">Connected Apps</a></li>
        <li><a href="#email" class="block rounded-md px-3 py-2 text-mist-700 hover:bg-mist-950/5 hover:text-mist-950 dark:text-mist-300 dark:hover:bg-white/5 dark:hover:text-white">Email to Podcast</a></li>
        <% if Current.user_admin? %>
          <li><a href="#demo" class="block rounded-md px-3 py-2 text-mist-700 hover:bg-mist-950/5 hover:text-mist-950 dark:text-mist-300 dark:hover:bg-white/5 dark:hover:text-white">Demo Mode</a></li>
        <% end %>
      </ul>
    </nav>

    <%# Mobile section nav (horizontal pills) %>
    <nav class="mb-6 flex gap-2 overflow-x-auto lg:hidden" aria-label="Settings sections">
      <a href="#voice" class="shrink-0 rounded-full border border-mist-200 px-3 py-1.5 text-sm text-mist-700 dark:border-mist-700 dark:text-mist-300">Voice</a>
      <% if Current.user.premium? || @subscription.present? %>
        <a href="#billing" class="shrink-0 rounded-full border border-mist-200 px-3 py-1.5 text-sm text-mist-700 dark:border-mist-700 dark:text-mist-300">Billing</a>
      <% end %>
      <a href="#extension" class="shrink-0 rounded-full border border-mist-200 px-3 py-1.5 text-sm text-mist-700 dark:border-mist-700 dark:text-mist-300">Extension</a>
      <a href="#api-tokens" class="shrink-0 rounded-full border border-mist-200 px-3 py-1.5 text-sm text-mist-700 dark:border-mist-700 dark:text-mist-300">API Tokens</a>
      <a href="#connected-apps" class="shrink-0 rounded-full border border-mist-200 px-3 py-1.5 text-sm text-mist-700 dark:border-mist-700 dark:text-mist-300">Connected</a>
      <a href="#email" class="shrink-0 rounded-full border border-mist-200 px-3 py-1.5 text-sm text-mist-700 dark:border-mist-700 dark:text-mist-300">Email</a>
      <% if Current.user_admin? %>
        <a href="#demo" class="shrink-0 rounded-full border border-mist-200 px-3 py-1.5 text-sm text-mist-700 dark:border-mist-700 dark:text-mist-300">Demo</a>
      <% end %>
    </nav>

    <div class="space-y-12">
      <%# Voice section %>
      <section id="voice" class="scroll-mt-6 grid grid-cols-1 gap-x-8 gap-y-6 border-b border-mist-950/10 pb-12 md:grid-cols-3 dark:border-white/10">
        <div>
          <h2 class="text-base/7 font-semibold text-mist-950 dark:text-white">Voice</h2>
          <p class="mt-1 text-sm/6 text-mist-500 dark:text-mist-400">Choose the voice for your podcast episodes. Changes save automatically.</p>
        </div>
        <div class="md:col-span-2">
          <%= form_with url: settings_path, method: :patch, data: { controller: "autosave" } do %>
            <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
              <% @voices.group_by(&:accent).each do |accent, voices| %>
                <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-mist-950/5 dark:bg-mist-800 dark:ring-white/10">
                  <div class="flex items-center justify-between px-4 pt-4 pb-2">
                    <h3 class="text-xs font-semibold tracking-wide text-mist-500 uppercase dark:text-mist-400"><%= accent %></h3>
                    <span class="text-xs text-mist-500 dark:text-mist-400"><%= voices.size %> voices</span>
                  </div>
                  <ul role="list" class="divide-y divide-mist-950/5 dark:divide-white/5">
                    <% voices.each do |voice| %>
                      <li data-controller="audio-preview" data-audio-preview-url-value="<%= voice.sample_url %>">
                        <label class="relative flex cursor-pointer items-center gap-3 px-4 py-2.5 transition-colors hover:bg-mist-950/[0.03] has-[:checked]:bg-mist-950/[0.04] dark:hover:bg-white/[0.03] dark:has-[:checked]:bg-white/5">
                          <input type="radio" name="voice" value="<%= voice.key %>"
                                 <%= "checked" if @selected_voice == voice.key %>
                                 data-action="change->autosave#submit"
                                 class="peer sr-only">

                          <span class="absolute inset-y-0 left-0 w-0.5 bg-mist-950 opacity-0 peer-checked:opacity-100 dark:bg-white" aria-hidden="true"></span>

                          <button type="button"
                                  data-audio-preview-target="button"
                                  data-action="click->audio-preview#toggle click->audio-preview#stopPropagation"
                                  class="flex size-8 shrink-0 items-center justify-center rounded-full bg-mist-950/5 text-mist-950 transition-colors hover:bg-mist-950/10 dark:bg-white/10 dark:text-white dark:hover:bg-white/15"
                                  aria-label="Preview <%= voice.name %>">
                            <span data-audio-preview-target="playIcon"><%= render "shared/icons/play", css_class: "size-4" %></span>
                            <span data-audio-preview-target="pauseIcon" class="hidden"><%= render "shared/icons/pause", css_class: "size-4" %></span>
                          </button>

                          <span class="flex min-w-0 flex-1 items-center gap-2">
                            <span class="text-sm font-medium text-mist-950 dark:text-white"><%= voice.name %></span>
                            <span class="text-sm text-mist-500 dark:text-mist-400"><%= voice.gender %></span>
                            <% if voice.chirphd? %>
                              <span title="Premium voice" class="inline-flex">
                                <%= render "shared/icons/sparkles", css_class: "size-3 text-amber-600 dark:text-amber-400" %>
                              </span>
                            <% end %>
                          </span>

                          <span class="text-mist-950 opacity-0 peer-checked:opacity-100 dark:text-white" aria-hidden="true">
                            <%= render "shared/icons/check_circle_solid" %>
                          </span>
                        </label>
                      </li>
                    <% end %>
                  </ul>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>

      <% if Current.user.premium? || @subscription.present? %>
        <%# Billing section %>
        <section id="billing" class="scroll-mt-6 grid grid-cols-1 gap-x-8 gap-y-6 border-b border-mist-950/10 pb-12 md:grid-cols-3 dark:border-white/10">
          <div>
            <h2 class="text-base/7 font-semibold text-mist-950 dark:text-white">Billing</h2>
            <p class="mt-1 text-sm/6 text-mist-500 dark:text-mist-400">Manage your subscription and payment details.</p>
          </div>
          <div class="md:col-span-2">
            <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-mist-950/5 dark:bg-mist-800 dark:ring-white/10">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <div class="space-y-1">
                  <% if @subscription.present? %>
                    <div class="flex items-center gap-2">
                      <p class="text-sm font-medium text-mist-950 dark:text-white"><%= @subscription.plan_name %></p>
                      <span class="inline-flex items-center rounded-full px-2 py-1 text-xs font-medium <%= status_pill_classes(@subscription) %>"><%= status_pill_label(@subscription) %></span>
                    </div>
                    <% unless @subscription.canceled? %>
                      <% renewal_date = @subscription.canceling? ? @subscription.cancel_at : @subscription.current_period_end %>
                      <p class="text-sm text-mist-500 dark:text-mist-400">
                        <%= @subscription.canceling? ? "Ends" : "Renews" %> <%= renewal_date.strftime("%B %-d, %Y") %> &middot; <%= @subscription.plan_display_price %>
                      </p>
                    <% end %>
                  <% end %>
                </div>
                <%= link_to manage_billing_cta_label(@subscription), billing_path, class: "#{button_classes(type: :secondary)} self-start sm:self-auto" %>
              </div>
            </div>
          </div>
        </section>
      <% end %>

      <%# Browser Extension section %>
      <section id="extension" class="scroll-mt-6 grid grid-cols-1 gap-x-8 gap-y-6 border-b border-mist-950/10 pb-12 md:grid-cols-3 dark:border-white/10">
        <div>
          <h2 class="text-base/7 font-semibold text-mist-950 dark:text-white">Browser Extension</h2>
          <p class="mt-1 text-sm/6 text-mist-500 dark:text-mist-400">Send articles to your podcast from any webpage.</p>
        </div>
        <div class="md:col-span-2">
          <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-mist-950/5 dark:bg-mist-800 dark:ring-white/10">
            <%= link_to "Manage Extension", settings_extensions_path, class: button_classes(type: :secondary) %>
          </div>
        </div>
      </section>

      <%# API Tokens section %>
      <section id="api-tokens" class="scroll-mt-6 grid grid-cols-1 gap-x-8 gap-y-6 border-b border-mist-950/10 pb-12 md:grid-cols-3 dark:border-white/10">
        <div>
          <h2 class="text-base/7 font-semibold text-mist-950 dark:text-white">API Tokens</h2>
          <p class="mt-1 text-sm/6 text-mist-500 dark:text-mist-400">Create and manage personal access tokens for programmatic access to PodRead.</p>
        </div>
        <div class="md:col-span-2">
          <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-mist-950/5 dark:bg-mist-800 dark:ring-white/10">
            <%= link_to "Manage API Tokens", settings_api_tokens_path, class: button_classes(type: :secondary) %>
          </div>
        </div>
      </section>

      <%# Connected Apps section %>
      <section id="connected-apps" class="scroll-mt-6 grid grid-cols-1 gap-x-8 gap-y-6 border-b border-mist-950/10 pb-12 md:grid-cols-3 dark:border-white/10">
        <div>
          <h2 class="text-base/7 font-semibold text-mist-950 dark:text-white">Connected Apps</h2>
          <p class="mt-1 text-sm/6 text-mist-500 dark:text-mist-400">Apps authorized to access your PodRead account via OAuth.</p>
        </div>
        <div class="md:col-span-2">
          <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-mist-950/5 dark:bg-mist-800 dark:ring-white/10">
            <% if @connected_apps.any? %>
              <ul role="list" class="divide-y divide-mist-200 dark:divide-mist-700">
                <% @connected_apps.each do |connected| %>
                  <li class="flex items-center justify-between py-4 first:pt-0 last:pb-0">
                    <div class="flex items-center gap-3">
                      <%= oauth_app_badge(connected[:app]) %>
                      <div>
                        <p class="text-sm font-medium text-mist-950 dark:text-white"><%= connected[:app].name %></p>
                        <p class="text-xs text-mist-500 dark:text-mist-400">
                          Connected
                          <time datetime="<%= connected[:authorized_at].iso8601 %>"
                                title="<%= connected[:authorized_at].strftime("%B %-d, %Y at %-I:%M %p") %>"
                                aria-label="Connected <%= connected[:authorized_at].strftime("%B %-d, %Y at %-I:%M %p") %>"
                                class="underline decoration-dotted decoration-mist-400 dark:decoration-mist-600 underline-offset-2 cursor-help">
                            <%= time_ago_in_words(connected[:authorized_at]) %> ago
                          </time>
                        </p>
                      </div>
                    </div>
                    <%= button_to "Disconnect",
                        settings_connected_app_path(connected[:app]),
                        method: :delete,
                        class: button_classes(type: :danger),
                        data: { turbo_confirm: "Disconnect #{connected[:app].name}? You'll need to re-authorize to use it again." } %>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-sm text-mist-500 dark:text-mist-400">
                No apps connected. You can connect apps like
                <a href="<%= help_claude_path %>" class="text-mist-950 underline dark:text-white">Claude</a>
                to create podcast episodes from chat.
              </p>
            <% end %>
          </div>
        </div>
      </section>

      <%# Email to Podcast section %>
      <section id="email" class="scroll-mt-6 grid grid-cols-1 gap-x-8 gap-y-6 pb-12 md:grid-cols-3">
        <div>
          <h2 class="text-base/7 font-semibold text-mist-950 dark:text-white">Email to Podcast</h2>
          <p class="mt-1 text-sm/6 text-mist-500 dark:text-mist-400">Create podcast episodes by forwarding content via email.</p>
        </div>
        <div class="md:col-span-2">
          <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-mist-950/5 dark:bg-mist-800 dark:ring-white/10">
            <% if Current.user.email_episodes_enabled? %>
              <p class="mb-4 text-sm/6 text-mist-500 dark:text-mist-400">
                Send content to this address to create podcast episodes:
              </p>

              <div class="mb-4 flex items-stretch gap-px rounded-md bg-mist-950/5 ring-1 ring-mist-950/10 dark:bg-white/5 dark:ring-white/10">
                <code class="flex-1 rounded-l-md bg-white/60 px-3 py-2 font-mono text-sm break-all text-mist-950 dark:bg-mist-800/60 dark:text-white">
                  <%= demo_mode? ? '•••••••••' : @email_ingest_address %>
                </code>
                <%= render "shared/clipboard_button",
                  content: @email_ingest_address,
                  title: "Copy email address",
                  icon: "copy",
                  button_class: "flex shrink-0 items-center rounded-r-md bg-white/60 px-3 text-mist-500 hover:bg-white hover:text-mist-950 dark:bg-mist-800/60 dark:text-mist-400 dark:hover:bg-mist-800 dark:hover:text-white transition-colors cursor-pointer"
                %>
              </div>

              <div class="mb-4 flex flex-wrap gap-2">
                <%= button_to "Disable", settings_email_episodes_path,
                    method: :delete, class: button_classes(type: :danger) %>
              </div>

              <div class="border-t border-mist-200 pt-4 dark:border-mist-700">
                <%= form_with url: settings_path, method: :patch, data: { controller: "autosave" } do %>
                  <label class="group flex cursor-pointer items-center gap-3">
                    <input type="hidden" name="email_episode_confirmation" value="0">
                    <input type="checkbox" name="email_episode_confirmation" value="1"
                           <%= "checked" if Current.user.email_episode_confirmation? %>
                           data-action="change->autosave#submit"
                           class="peer sr-only">
                    <span class="relative h-6 w-11 rounded-full bg-mist-200 transition-colors duration-200
                                 after:absolute after:top-0.5 after:left-0.5 after:h-5 after:w-5
                                 after:rounded-full after:bg-white after:transition-transform after:duration-200
                                 after:content-[''] peer-checked:bg-mist-950 peer-checked:after:translate-x-5
                                 peer-focus:ring-2 peer-focus:ring-mist-950/50
                                 dark:bg-mist-700 dark:after:bg-mist-950 dark:peer-checked:bg-white
                                 dark:peer-focus:ring-white/50"></span>
                    <span class="text-sm/6 text-mist-950 dark:text-white">Send confirmation email when episodes are created</span>
                  </label>
                <% end %>
              </div>

              <details class="group mt-4 border-t border-mist-200 pt-4 dark:border-mist-700">
                <summary class="flex cursor-pointer list-none items-center gap-2 text-sm/6 text-mist-500 hover:text-mist-950 dark:text-mist-400 dark:hover:text-white">
                  <%= render "shared/icons/chevron", css_class: "size-3 transition-transform group-open:rotate-90" %>
                  Advanced
                </summary>
                <div class="mt-3">
                  <%= button_to "Regenerate Address", settings_email_token_path,
                      method: :post, class: button_classes(type: :secondary),
                      data: { turbo_confirm: "This will invalidate your current email address. Continue?" } %>
                  <p class="mt-2 text-xs/5 text-mist-500 dark:text-mist-400">
                    Invalidates your current address and issues a new one.
                  </p>
                </div>
              </details>
            <% else %>
              <p class="mb-4 text-sm/6 text-mist-500 dark:text-mist-400">
                Enable email episodes to get a unique email address for creating episodes by forwarding content.
              </p>

              <%= button_to "Enable Email Episodes", settings_email_episodes_path,
                  method: :post, class: button_classes(type: :primary) %>
            <% end %>
          </div>
        </div>
      </section>

      <% if Current.user_admin? %>
        <%# Demo Mode section %>
        <section id="demo" class="scroll-mt-6 grid grid-cols-1 gap-x-8 gap-y-6 border-t border-mist-950/10 pt-12 md:grid-cols-3 dark:border-white/10">
          <div>
            <h2 class="text-base/7 font-semibold text-mist-950 dark:text-white">Demo Mode</h2>
            <p class="mt-1 text-sm/6 text-mist-500 dark:text-mist-400">Hide personal info like email and RSS feed ID for screen recordings.</p>
          </div>
          <div class="md:col-span-2">
            <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-mist-950/5 dark:bg-mist-800 dark:ring-white/10">
              <%= button_to settings_demo_mode_path, method: :post, class: "#{button_classes(type: demo_mode? ? :danger : :primary)}" do %>
                <%= demo_mode? ? 'Disable Demo Mode' : 'Enable Demo Mode' %>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>
    </div>
  </div>
</div>
