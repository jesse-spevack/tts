<%# Placeholder — styled and componentized in agent-team-q8y.5 %>
<div class="mx-auto max-w-4xl">
  <%= render "shared/back_link", path: settings_path, text: "Back to Settings" %>
  <%= render "shared/page_header", title: "API Tokens" %>

  <%= button_to "Create token", settings_api_tokens_path, method: :post,
        class: "rounded bg-mist-900 px-3 py-2 text-sm font-medium text-white" %>

  <% if @api_tokens.any? %>
    <table class="mt-6 w-full text-sm">
      <thead>
        <tr>
          <th class="py-2 text-left">Prefix</th>
          <th class="py-2 text-left">Created</th>
          <th class="py-2 text-left">Last used</th>
          <th class="py-2 text-left"></th>
        </tr>
      </thead>
      <tbody>
        <% @api_tokens.each do |token| %>
          <tr>
            <td class="py-2 font-mono"><%= token.token_prefix || "(legacy)" %></td>
            <td class="py-2"><%= token.created_at.strftime("%b %d, %Y") %></td>
            <td class="py-2"><%= token.last_used_at ? "#{time_ago_in_words(token.last_used_at)} ago" : "Never" %></td>
            <td class="py-2">
              <%= button_to "Revoke", settings_api_token_path(token), method: :delete,
                    data: { turbo_confirm: "Revoke this token? Any script using it will stop working." },
                    class: "text-red-600 hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="mt-6 text-mist-500">You haven't created any tokens yet.</p>
  <% end %>
</div>
