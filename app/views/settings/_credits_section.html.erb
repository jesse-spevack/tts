<% variant = credits_card_variant(Current.user) %>
<% if variant %>
  <section id="credits" class="scroll-mt-6 grid grid-cols-1 gap-x-8 gap-y-6 border-b border-mist-950/10 pb-12 md:grid-cols-3 dark:border-white/10">
    <div>
      <h2 class="text-base/7 font-semibold text-mist-950 dark:text-white">Credits</h2>
      <p class="mt-1 text-sm/6 text-mist-500 dark:text-mist-400">Pay-as-you-go episode packs.</p>
    </div>
    <div class="md:col-span-2">
      <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-mist-950/5 dark:bg-mist-800 dark:ring-white/10">
        <% case variant %>
        <% when :balance %>
          <div class="space-y-1">
            <p class="text-sm text-mist-500 dark:text-mist-400">
              You have <span class="font-medium text-mist-950 dark:text-white"><%= pluralize(Current.user.credits_remaining, "episode credit") %></span> remaining.
            </p>
            <p class="text-sm text-mist-500 dark:text-mist-400">Credits never expire. Buy more below.</p>
          </div>
        <% when :empty_state %>
          <p class="text-sm font-medium text-mist-950 dark:text-white">
            Pay as you go.
          </p>
          <p class="mt-1 text-sm text-mist-500 dark:text-mist-400">
            Pick a pack. Credits never expire.
          </p>
        <% end %>
        <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
          <% AppConfig::Credits::PACKS.each do |pack| %>
            <%= render "settings/credit_pack_card",
                       pack: pack,
                       highlight: pack[:size] == 20,
                       submit_label: (variant == :balance ? "Buy More Credits" : "Buy Credit Pack") %>
          <% end %>
        </div>
      </div>
    </div>
  </section>
<% end %>
