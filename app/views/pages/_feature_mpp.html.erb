<%# Feature illustration: MPP 402 → pay → narration flow %>
<div class="rounded-xl bg-mist-50 dark:bg-mist-950 shadow-lg font-mono text-sm">
  <%# Traffic light dots %>
  <div class="flex items-center gap-1.5 px-4 pt-3 pb-2">
    <span class="inline-block h-2.5 w-2.5 rounded-full bg-red-400"></span>
    <span class="inline-block h-2.5 w-2.5 rounded-full bg-yellow-400"></span>
    <span class="inline-block h-2.5 w-2.5 rounded-full bg-green-400"></span>
  </div>

  <%# Request %>
  <div class="px-4 pb-2">
    <p>
      <span class="text-mist-400">$</span>
      <span class="text-mist-950 dark:text-white"> curl </span>
      <span class="text-green-700 dark:text-green-400">https://podread.app/api/v1/mpp/narrations</span>
    </p>
  </div>

  <%# 402 response %>
  <div class="px-4 pb-3">
    <p><span class="text-mist-500 dark:text-mist-400">HTTP/1.1 </span><span class="text-mist-950 dark:text-white">402 Payment Required</span></p>
    <p><span class="text-mist-500 dark:text-mist-400">WWW-Authenticate:</span> <span class="text-mist-950 dark:text-white">Payment</span></p>
    <p class="pl-4">
      <span class="text-mist-500 dark:text-mist-400">realm=</span><span class="text-green-700 dark:text-green-400">"podread.app"</span><span class="text-mist-500 dark:text-mist-400">,</span>
    </p>
    <p class="pl-4">
      <span class="text-mist-500 dark:text-mist-400">amount=</span><span class="text-mist-950 dark:text-white tabular-nums">750000</span>
    </p>
  </div>

  <div class="mx-4 border-t border-mist-200 dark:border-mist-800"></div>

  <%# Pay + response %>
  <div class="px-4 pt-3 pb-4">
    <p>
      <span class="text-mist-400">$</span>
      <span class="text-mist-950 dark:text-white"> npx mppx pay</span>
    </p>
    <p>
      <span class="text-emerald-700 dark:text-emerald-400">✓</span>
      <span class="text-mist-700 dark:text-mist-300"> Paid $0.75 on Tempo</span>
    </p>
    <p class="mt-1">
      <span class="text-mist-950 dark:text-white">{ </span><span class="text-mist-500 dark:text-mist-400">"narration_id"</span><span class="text-mist-950 dark:text-white">: </span><span class="text-green-700 dark:text-green-400">"nar_aB3xK9…"</span><span class="text-mist-950 dark:text-white"> }</span>
    </p>
  </div>
</div>
