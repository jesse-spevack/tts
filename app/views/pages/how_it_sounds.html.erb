<% sections = [
     { id: "sample-audio", label: "Sample audio" },
     { id: "how-it-works", label: "How it works" }
   ] %>
<% content_for :right_toc do %>
  <%= render "shared/help_right_toc", steps: sections %>
<% end %>
<%= render layout: "shared/help_layout", locals: { current: :how_it_sounds } do %>

  <section class="pb-12">
    <h2 class="text-lg/8 font-semibold text-mist-950 dark:text-white">How It Sounds</h2>
    <p class="mt-2 text-sm/6 text-mist-700 dark:text-mist-400">Listen to sample audio generated by PodRead.</p>

    <%# Section body. Active state in the right-rail ToC is driven by      %>
    <%# aria-current="step", set by the scroll-spy controller mounted on   %>
    <%# the help_layout root (see shared/_help_layout.html.erb). Each      %>
    <%# section heading is the scroll-spy target — its data-step matches   %>
    <%# the link's data-step in shared/_help_right_toc.html.erb.           %>
    <h3 id="sample-audio" data-scroll-spy-target="step" data-step="sample-audio" class="mt-6 scroll-mt-24 text-base font-semibold text-mist-950 dark:text-white">Sample audio</h3>
    <div class="mt-4">
      <%= render "shared/card", padding: "p-4 sm:p-6" do %>
        <%= render "shared/audio_player", source: "/sample-standard-d.mp3", label: "Felix — British, Standard voice" %>
      <% end %>
    </div>

    <h3 id="how-it-works" data-scroll-spy-target="step" data-step="how-it-works" class="mt-8 scroll-mt-24 text-base font-semibold text-mist-950 dark:text-white">How it works</h3>
    <ol class="mt-4 space-y-4 text-sm/6 text-mist-700 dark:text-mist-400">
      <li class="flex gap-4">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-mist-950 text-white dark:bg-white dark:text-mist-950 flex items-center justify-center font-semibold text-sm">1</span>
        <span class="pt-1">Upload a txt or markdown file</span>
      </li>
      <li class="flex gap-4">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-mist-950 text-white dark:bg-white dark:text-mist-950 flex items-center justify-center font-semibold text-sm">2</span>
        <span class="pt-1">We convert it to natural-sounding audio</span>
      </li>
      <li class="flex gap-4">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-mist-950 text-white dark:bg-white dark:text-mist-950 flex items-center justify-center font-semibold text-sm">3</span>
        <span class="pt-1">Listen in your favorite podcast app via your own RSS feed link</span>
      </li>
    </ol>

    <div class="mt-8 text-center">
      <%= link_to "Get started", root_path(anchor: "signup"), class: button_classes(type: :primary) %>
    </div>
  </section>
<% end %>
