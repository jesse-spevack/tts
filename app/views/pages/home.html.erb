<%# Home Page — Based on Variation 02
  Section order: Navbar (centered links) > Hero (demo on background, wallpaper blue) >
  Features (3-col with demos) > Stats (with graph) > Testimonial (large quote) >
  FAQs (2-col accordion) > Pricing (multi-tier) > CTA (simple) > Footer (link categories)
%>

<%# ===== Navbar ===== %>
<%= render "shared/marketing/navbar_centered_links",
  links: [
    { label: "How it works", href: "#features" },
    { label: "Pricing", href: "#pricing" },
    { label: "Docs", href: docs_authentication_path },
    { label: "Blog", href: blog_path },
    { label: "About", href: about_path },
  ],
  actions: render("shared/marketing/auth_actions") %>

<%# ===== Hero (demo on background) ===== %>
<%= render "shared/marketing/hero_demo_bg",
  eyebrow: render("shared/marketing/announcement_badge",
    tag: "button",
    text: "Now with natural-sounding HD voices",
    cta: "Hear how it sounds",
    variant: "overlay",
    data: { action: "click->sample-modal#open" }),
  headline: "Turn any article into a podcast episode.",
  subheadline: tag.p("Paste a URL, upload a file, or drop in text. PodRead converts it to audio and delivers it to your private podcast feed. Listen in any podcast app."),
  cta: render("shared/marketing/cta_button", label: "Create my feed", plan: "free", class: "inline-flex shrink-0 items-center justify-center gap-1 rounded-full text-sm/7 font-medium px-5 py-2.5 bg-white text-mist-950 hover:bg-mist-200"),
  demo: render("pages/hero_demo"),
  wallpaper_color: "blue" %>

<%# ===== Features (5 ways) ===== %>
<%= render layout: "shared/marketing/features_three_col_demos", locals: {
  id: "features",
  headline: "Every way to turn words into audio.",
  subheadline: "However you find articles worth reading, PodRead has a way to get them into your ears."
} do %>
  <%= render layout: "shared/marketing/features_three_col_demos_card", locals: {
    headline: "Paste a URL",
    subheadline: "Drop in a link to any article. PodRead extracts the content, skips the clutter, and turns it into a podcast episode."
  } do %>
    <%= render layout: "shared/marketing/screenshot", locals: { wallpaper: "blue", placement: "bottom-right" } do %>
      <%= render "pages/feature_url" %>
    <% end %>
  <% end %>

  <%= render layout: "shared/marketing/features_three_col_demos_card", locals: {
    headline: "Paste text",
    subheadline: "Copy and paste any text directly. Great for paywalled articles, PDFs, or anything you've already got on your clipboard."
  } do %>
    <%= render layout: "shared/marketing/screenshot", locals: { wallpaper: "purple", placement: "top-left" } do %>
      <%= render "pages/feature_paste" %>
    <% end %>
  <% end %>

  <%= render layout: "shared/marketing/features_three_col_demos_card", locals: {
    headline: "Upload a file",
    subheadline: "Upload a .txt or .md file and PodRead turns it into an episode. Perfect for notes, drafts, or long-form content."
  } do %>
    <%= render layout: "shared/marketing/screenshot", locals: { wallpaper: "brown", placement: "bottom-left" } do %>
      <%= render "pages/feature_upload" %>
    <% end %>
  <% end %>

  <%= render layout: "shared/marketing/features_three_col_demos_card", locals: {
    headline: "Email to podcast",
    subheadline: "Forward any article or newsletter to your PodRead email address and it shows up as an episode in your feed."
  } do %>
    <%= render layout: "shared/marketing/screenshot", locals: { wallpaper: "green", placement: "bottom-right" } do %>
      <%= render "pages/feature_email" %>
    <% end %>
  <% end %>

  <%= render layout: "shared/marketing/features_three_col_demos_card", locals: {
    headline: "Browser extension",
    subheadline: "One click from any article you're reading. The browser extension sends it straight to your podcast feed."
  } do %>
    <%= render layout: "shared/marketing/screenshot", locals: { wallpaper: "orange", placement: "top-left" } do %>
      <%= render "pages/feature_extension" %>
    <% end %>
  <% end %>

  <%= render layout: "shared/marketing/features_three_col_demos_card", locals: {
    headline: "API",
    subheadline: "Build text-to-speech into your own workflows. Create a personal API token at /settings/api_tokens, send content programmatically, and get episodes in your feed."
  } do %>
    <%= render layout: "shared/marketing/screenshot", locals: { wallpaper: "brown", placement: "bottom-left" } do %>
      <%= render "pages/feature_api" %>
    <% end %>
  <% end %>

  <%= render layout: "shared/marketing/features_three_col_demos_card", locals: {
    headline: "Machine Payments",
    subheadline: safe_join([
      "Pay per narration with stablecoin via the Machine Payments Protocol — the open protocol for machine-to-machine payments. ",
      link_to("Read the docs", docs_mpp_path, class: "font-medium text-mist-950 underline hover:text-mist-700 dark:text-white dark:hover:text-mist-300")
    ])
  } do %>
    <%= render layout: "shared/marketing/screenshot", locals: { wallpaper: "purple", placement: "top-right" } do %>
      <%= render "pages/feature_mpp" %>
    <% end %>
  <% end %>
<% end %>

<%# ===== Stats (with graph) ===== %>
<%= render layout: "shared/marketing/stats_graph", locals: {
  eyebrow: "Growing every day",
  headline: "Hundreds of articles turned into podcast episodes.",
  subheadline: "PodRead helps people listen to the articles they save but never get around to reading. Every day, more people are turning their reading lists into listening lists."
} do %>
  <%= render "shared/marketing/stat_border", stat: number_with_delimiter(@episode_count), text: "Episodes created by readers who'd rather listen." %>
  <%= render "shared/marketing/stat_border", stat: number_with_delimiter(@user_count), text: "Listeners who turned their reading list into a playlist." %>
<% end %>

<%# ===== Testimonial (large quote) ===== %>
<%= render "shared/marketing/testimonial_large_quote",
  quote: tag.p("I built PodRead because I had dozens of articles open in browser tabs that I never made time to read. Now I listen to them when I'm doing chores or on a run. I use it every day to stay informed and productive."),
  name: "Jesse Spevack",
  byline: "Founder of PodRead",
  img_src: "/jesse-profile.jpg" %>

<%# ===== FAQs (2-column accordion) ===== %>
<%= render layout: "shared/marketing/faqs_two_col_accordion", locals: {
  id: "faqs",
  headline: "Questions & Answers"
} do %>
  <%= render "shared/marketing/faq_item",
    id: "faq-1",
    question: "Is it really free?",
    answer: "Yes. 2 episodes per month on the free plan, no credit card required. Beyond that, buy a credit pack — starts at $9.99 for 5 episodes." %>
  <%= render "shared/marketing/faq_item",
    id: "faq-2",
    question: "Does it sound robotic?",
    answer: tag.p(safe_join(["Not at all. PodRead uses the latest text-to-speech technology. All our voice options sound natural and pleasant to listen to, even for long articles. ", tag.button("Hear how it sounds", type: "button", data: { action: "click->sample-modal#open" }, class: "inline font-medium text-mist-950 underline hover:text-mist-700 dark:text-white dark:hover:text-mist-300"), "."])) %>
  <%= render "shared/marketing/faq_item",
    id: "faq-3",
    question: "Which podcast apps work with PodRead?",
    answer: "Any podcast app that supports custom RSS feeds. That includes Apple Podcasts, Spotify, Overcast, Pocket Casts, Castro, and many more. You don't need to install any new apps." %>
  <%= render "shared/marketing/faq_item",
    id: "faq-4",
    question: "What content can I convert?",
    answer: "Web articles (via URL), pasted text, and uploaded markdown files. If you can read it, PodRead can turn it into audio." %>
  <%= render "shared/marketing/faq_item",
    id: "faq-5",
    question: "How is PodRead different from NotebookLM?",
    answer: "NotebookLM generates a podcast-style conversation that summarizes your content. PodRead converts the original text into audio and delivers it straight to your podcast app — Apple Podcasts, Spotify, Overcast, or wherever you already listen. You get the full article, not a summary, and it lives alongside all your other podcasts instead of in a separate app." %>
<% end %>

<%# ===== Pricing (Free + three credit packs) ===== %>
<section id="pricing" class="py-16">
  <div class="mx-auto w-full max-w-2xl px-6 md:max-w-3xl lg:max-w-7xl lg:px-10 flex flex-col gap-16">
    <div class="flex flex-col items-center gap-6">
      <h1 class="font-display text-5xl/12 tracking-tight text-balance sm:text-[5rem]/20 text-mist-950 dark:text-white">Simple, honest pricing.</h1>
      <div class="text-lg/8 text-mist-700 dark:text-mist-400 flex max-w-xl flex-col gap-4 text-center">
        <p>Start free. When you're ready for more, buy a credit pack.</p>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-2 lg:grid-cols-4">
      <%= render "shared/marketing/pricing_hero_multi_plan",
        name: "Free",
        price: "$0",
        period: "/month",
        subheadline: "Try it out, no credit card required.",
        features: [
          "Private podcast feed",
          "Paste links, text, or upload files",
          "Choose your voice",
          "2 episodes per month",
          "Up to 15,000 characters",
        ],
        cta_html: render("shared/marketing/cta_button", label: "Create my feed", plan: "free", class: "inline-flex shrink-0 items-center justify-center gap-1 rounded-full text-sm/7 font-medium px-5 py-2.5 bg-mist-950/5 text-mist-950 hover:bg-mist-950/10 dark:bg-white/10 dark:text-white dark:hover:bg-white/15") %>

      <% AppConfig::Credits::PACKS.each do |pack| %>
        <% dollars = format("%.2f", pack[:price_cents] / 100.0) %>
        <% per_credit = format("%.2f", pack[:price_cents] / 100.0 / pack[:size]) %>
        <% is_best = pack[:size] == 20 %>
        <%= render "shared/marketing/pricing_hero_multi_plan",
          name: pack[:label],
          price: "$#{dollars}",
          period: "/ #{pack[:size]} credits",
          subheadline: "$#{per_credit} per credit. Credits never expire.",
          badge: (is_best ? "Best value" : nil),
          features: [
            "#{pack[:size]} episodes",
            "Up to 50,000 characters per episode",
            "All voices available",
            "No recurring charges",
          ],
          cta_html: render("shared/marketing/cta_button", label: "Buy #{pack[:label]}", plan: "credit_pack", pack_size: pack[:size], class: "inline-flex shrink-0 items-center justify-center gap-1 rounded-full text-sm/7 font-medium px-5 py-2.5 #{is_best ? 'bg-mist-950 text-white hover:bg-mist-800 dark:bg-white dark:text-mist-950 dark:hover:bg-mist-200' : 'bg-mist-950/5 text-mist-950 hover:bg-mist-950/10 dark:bg-white/10 dark:text-white dark:hover:bg-white/15'}") %>
      <% end %>
    </div>
  </div>
</section>

<%# ===== Call to Action ===== %>
<% final_cta_classes = "inline-flex shrink-0 items-center justify-center gap-1 rounded-full text-sm/7 font-medium px-5 py-2.5 bg-mist-950 text-white hover:bg-mist-800 dark:bg-white dark:text-mist-950 dark:hover:bg-mist-200" %>
<% final_cta = if authenticated?
     link_to("Start listening free", new_episode_path, class: final_cta_classes)
   else
     tag.button("Start listening free", type: "button", data: { action: "click->signup-modal#open", plan: "free" }, class: final_cta_classes)
   end %>
<%= render "shared/marketing/cta_simple",
  headline: "Your reading list isn't going to listen to itself.",
  subheadline: tag.p("Start converting articles into podcast episodes today. Free to try, no credit card required."),
  cta: tag.div(class: "flex items-center gap-4") do
    safe_join([
      final_cta,
      link_to("#features", class: "inline-flex items-center gap-2 text-sm/7 font-medium text-mist-950 dark:text-white") do
        safe_join(["See how it works ", tag.svg(tag.path(d: "M.22.22a.75.75 0 011.06 0l3.25 3.25a.75.75 0 010 1.06L1.28 7.78A.75.75 0 01.22 6.72L2.94 4 .22 1.28a.75.75 0 010-1.06z", fill_rule: "evenodd", clip_rule: "evenodd"), width: "5", height: "8", viewBox: "0 0 5 8", fill: "currentColor", class: "inline-block shrink-0")])
      end
    ])
  end %>

<%# ===== Footer (link categories) ===== %>
<%= render "shared/marketing/footer_categories",
  categories: [
    {
      title: "Product",
      links: [
        { label: "How it works", href: "#features" },
        { label: "Pricing", href: "#pricing" },
        { label: "Browser extension", href: help_extension_path },
      ]
    },
    {
      title: "About",
      links: [
        { label: "Our story", href: about_path },
      ]
    },
    {
      title: "Connect",
      links: [
        { label: "Twitter", href: "https://x.com/pod_read" },
        { label: "GitHub", href: "https://github.com/jesse-spevack/tts/blob/main/LICENSE.md" },
        { label: "Essays", href: "https://verynormal.info" },
      ]
    },
    {
      title: "Support",
      links: [
        { label: "Help Center", href: how_it_sounds_path },
        { label: "Contact", href: "mailto:jspevack@gmail.com" },
        { label: "FAQ", href: "#faqs" },
      ]
    },
    {
      title: "Legal",
      links: [
        { label: "Privacy Policy", href: privacy_path },
        { label: "Terms of Service", href: terms_path },
      ]
    },
  ] %>
