<%= render layout: "shared/help_layout", locals: { current: :splitting_articles } do %>

  <section class="pb-12"
           data-controller="scroll-spy"
           data-scroll-spy-active-class="text-mist-950 font-medium dark:text-white"
           data-scroll-spy-inactive-class="text-mist-500 dark:text-mist-400">
    <h2 class="text-lg/8 font-semibold text-mist-950 dark:text-white">Splitting long articles</h2>
    <p class="mt-2 text-sm/6 text-mist-700 dark:text-mist-400">
      When an article exceeds your plan's character limit, the URL fetcher will fail.
      You can still listen to the article — just paste the text and split it across
      two episodes. Here's how.
    </p>

    <%# Step nav — sticky on desktop, plain inline on mobile. %>
    <nav aria-label="Steps in this guide"
         class="mt-6 mb-10 flex flex-wrap gap-x-4 gap-y-2 text-sm/6 text-mist-500 dark:text-mist-400 sm:sticky sm:top-4 sm:z-10 sm:bg-mist-50 sm:dark:bg-mist-950/80 sm:backdrop-blur sm:py-3 sm:rounded-lg sm:px-3">
      <a href="#step-1" data-scroll-spy-target="link" data-step="1"
         class="hover:text-mist-950 dark:hover:text-white">1. Spot the error</a>
      <a href="#step-2" data-scroll-spy-target="link" data-step="2"
         class="hover:text-mist-950 dark:hover:text-white">2. Open the paste tab</a>
      <a href="#step-3" data-scroll-spy-target="link" data-step="3"
         class="hover:text-mist-950 dark:hover:text-white">3. Paste the first half</a>
      <a href="#step-4" data-scroll-spy-target="link" data-step="4"
         class="hover:text-mist-950 dark:hover:text-white">4. Repeat for the rest</a>
    </nav>

    <%# Step 1 ----------------------------------------------------------- %>
    <article id="step-1" data-scroll-spy-target="step" data-step="1" class="scroll-mt-24 mb-12">
      <h3 class="text-base font-semibold text-mist-950 dark:text-white">1. Spot the error on your episode list</h3>
      <p class="mt-2 text-sm/6 text-mist-700 dark:text-mist-400">
        When a URL is too long, the failed episode card shows a red message and a tip.
        That tip is what brought you here.
      </p>

      <div class="mt-4 max-w-md">
        <%= render "shared/demo_browser_frame" do %>
          <div class="w-full bg-white dark:bg-mist-900 rounded-md p-4 space-y-1">
            <div class="flex items-center gap-3">
              <span class="flex size-2 rounded-full flex-shrink-0 bg-rose-500"></span>
              <p class="text-sm font-medium text-mist-950 dark:text-white truncate">Processing...</p>
            </div>
            <p class="text-sm/6 text-mist-500 dark:text-mist-400 pl-5">
              <span class="inline-flex items-center gap-1">
                <span class="text-red-600 dark:text-red-400">✗</span>
                <span>Failed</span>
              </span>
              &mdash; <span class="text-rose-600 dark:text-rose-400">exceeds your plan's 15,000 character limit (16,305 characters)</span>
            </p>
            <p class="text-sm/6 text-mist-500 dark:text-mist-400 pl-5">
              Tip: split it across two episodes.
              <span class="underline">Read more →</span>
            </p>
          </div>
        <% end %>
      </div>
    </article>

    <%# Step 2 ----------------------------------------------------------- %>
    <article id="step-2" data-scroll-spy-target="step" data-step="2" class="scroll-mt-24 mb-12">
      <h3 class="text-base font-semibold text-mist-950 dark:text-white">2. Open the new-episode form on the Paste tab</h3>
      <p class="mt-2 text-sm/6 text-mist-700 dark:text-mist-400">
        Click <strong class="text-mist-950 dark:text-white">New Episode</strong> in the
        navigation, then switch to the <strong class="text-mist-950 dark:text-white">Paste Text</strong>
        tab. (The button at the bottom of this guide takes you straight there.)
      </p>

      <div class="mt-4 max-w-md">
        <%= render "shared/demo_browser_frame" do %>
          <div class="w-full bg-white dark:bg-mist-900 rounded-md p-4">
            <nav class="flex gap-6 border-b border-mist-200 dark:border-mist-700">
              <span class="pb-2 text-sm font-medium text-mist-500 dark:text-mist-400">From URL</span>
              <span class="border-b-2 border-mist-950 dark:border-white pb-2 text-sm font-medium text-mist-950 dark:text-white">Paste Text</span>
              <span class="pb-2 text-sm font-medium text-mist-500 dark:text-mist-400">Upload File</span>
            </nav>
            <div class="mt-4 space-y-3">
              <div class="h-3 w-1/2 rounded bg-mist-100 dark:bg-mist-800"></div>
              <div class="h-32 w-full rounded-md border border-mist-200 dark:border-mist-700 bg-mist-50 dark:bg-mist-800/50"></div>
              <button class="rounded-md bg-mist-950 dark:bg-white px-4 py-2 text-sm font-medium text-white dark:text-mist-950">
                Create Episode
              </button>
            </div>
          </div>
        <% end %>
      </div>
    </article>

    <%# Step 3 ----------------------------------------------------------- %>
    <article id="step-3" data-scroll-spy-target="step" data-step="3" class="scroll-mt-24 mb-12">
      <h3 class="text-base font-semibold text-mist-950 dark:text-white">3. Paste the first half</h3>
      <p class="mt-2 text-sm/6 text-mist-700 dark:text-mist-400">
        Copy the article's text from your browser, paste roughly the first half into
        the text area, and give the episode a clear title — e.g.
        <em>"My Article (Part 1)"</em>. Paragraph breaks make natural splits.
      </p>

      <div class="mt-4 max-w-md">
        <%= render "shared/demo_browser_frame" do %>
          <div class="w-full bg-white dark:bg-mist-900 rounded-md p-4 space-y-3">
            <div>
              <label class="block text-xs font-medium text-mist-500 dark:text-mist-400 mb-1">Title</label>
              <div class="rounded-md border border-mist-200 dark:border-mist-700 bg-white dark:bg-mist-800 px-3 py-2 text-sm text-mist-950 dark:text-white">
                My Article (Part 1)
              </div>
            </div>
            <div>
              <label class="block text-xs font-medium text-mist-500 dark:text-mist-400 mb-1">Text</label>
              <div class="rounded-md border border-mist-200 dark:border-mist-700 bg-white dark:bg-mist-800 p-3 text-xs/5 text-mist-700 dark:text-mist-300 h-24 overflow-hidden">
                <p>The first half of the article goes here. You don't have to be exact — pick a paragraph break near the middle and copy everything above it...</p>
              </div>
              <p class="mt-1 text-xs text-mist-500 dark:text-mist-400">
                <span class="text-mist-950 dark:text-white">8,200</span> / 15,000 characters
              </p>
            </div>
            <button class="rounded-md bg-mist-950 dark:bg-white px-4 py-2 text-sm font-medium text-white dark:text-mist-950">
              Create Episode
            </button>
          </div>
        <% end %>
      </div>
    </article>

    <%# Step 4 ----------------------------------------------------------- %>
    <article id="step-4" data-scroll-spy-target="step" data-step="4" class="scroll-mt-24 mb-12">
      <h3 class="text-base font-semibold text-mist-950 dark:text-white">4. Repeat for the second half</h3>
      <p class="mt-2 text-sm/6 text-mist-700 dark:text-mist-400">
        Submit the first episode, then come back, paste the rest, and title it
        <em>"My Article (Part 2)"</em>. You'll end up with two episodes that play
        back-to-back in your podcast app.
      </p>

      <div class="mt-4 max-w-md">
        <%= render "shared/demo_browser_frame" do %>
          <div class="w-full bg-white dark:bg-mist-900 rounded-md p-4">
            <ul class="divide-y divide-mist-100 dark:divide-mist-800">
              <li class="flex items-center gap-3 py-2">
                <span class="flex size-2 rounded-full bg-yellow-500 animate-pulse"></span>
                <p class="text-sm font-medium text-mist-950 dark:text-white truncate">My Article (Part 2)</p>
                <span class="ml-auto text-xs text-mist-500 dark:text-mist-400">Preparing…</span>
              </li>
              <li class="flex items-center gap-3 py-2">
                <span class="flex size-2 rounded-full bg-green-500"></span>
                <p class="text-sm font-medium text-mist-950 dark:text-white truncate">My Article (Part 1)</p>
                <span class="ml-auto text-xs text-mist-500 dark:text-mist-400">5:42</span>
              </li>
            </ul>
          </div>
        <% end %>
      </div>
    </article>

    <div class="mt-10 flex flex-col sm:flex-row gap-3">
      <%= link_to "Open the paste form", new_episode_path(source: "paste"),
                  class: "inline-flex items-center justify-center rounded-md bg-mist-950 dark:bg-white px-4 py-2 text-sm font-medium text-white dark:text-mist-950 hover:bg-mist-800 dark:hover:bg-mist-100" %>
      <%= link_to "Back to your episodes", episodes_path,
                  class: "inline-flex items-center justify-center rounded-md border border-mist-200 dark:border-mist-700 px-4 py-2 text-sm font-medium text-mist-950 dark:text-white hover:bg-mist-100 dark:hover:bg-mist-800" %>
    </div>

    <p class="mt-6 text-xs text-mist-500 dark:text-mist-400">
      Limits today: 15,000 characters on the free plan, 50,000 on paid plans.
      Want longer episodes? <%= link_to "Upgrade your account", settings_path, class: "underline" %>.
    </p>
  </section>
<% end %>
