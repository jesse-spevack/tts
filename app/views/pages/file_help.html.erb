<%= render layout: "shared/help_layout", locals: { current: :file_help } do %>

  <section class="pb-12" data-controller="scroll-spy">
    <%# Page intro -------------------------------------------------------- %>
    <h2 class="max-w-[40ch] text-lg/8 font-semibold text-balance text-mist-950 dark:text-white">
      Upload a file
    </h2>
    <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
      Have a markdown or text file? Upload it and PodRead converts it to audio.
    </p>

    <%# Step jump-links. Active state is driven by aria-current="step",       %>
    <%# set by the scroll-spy controller.                                     %>
    <nav aria-label="Steps in this guide" class="mt-8 mb-10">
      <ol role="list" class="flex flex-wrap gap-1 text-sm/5 text-mist-500 dark:text-mist-400">
        <% steps = [
             { n: 1, label: "Have file ready" },
             { n: 2, label: "Open file tab" },
             { n: 3, label: "Drop in file" },
             { n: 4, label: "Wait for episode" }
           ] %>
        <% steps.each do |s| %>
          <li>
            <a href="#step-<%= s[:n] %>"
               data-scroll-spy-target="link" data-step="<%= s[:n] %>"
               class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-mist-500 hover:text-mist-950 hover:bg-mist-200/60 dark:text-mist-400 dark:hover:text-white dark:hover:bg-mist-800/60 aria-[current=step]:bg-mist-200 aria-[current=step]:text-mist-950 dark:aria-[current=step]:bg-mist-800 dark:aria-[current=step]:text-white">
              <span class="tabular-nums"><%= s[:n] %>.</span>
              <span><%= s[:label] %></span>
            </a>
          </li>
        <% end %>
      </ol>
    </nav>

    <%# Step body --------------------------------------------------------- %>
    <ol role="list" class="space-y-12">

      <%# Step 1 --------------------------------------------------------- %>
      <li id="step-1" data-scroll-spy-target="step" data-step="1" class="scroll-mt-24">
        <article class="grid grid-cols-[auto_1fr] gap-x-4">
          <%= render "pages/splitting_step_badge", n: 1 %>
          <div class="min-w-0">
            <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
              Have your file ready
            </h3>
            <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              Supported file types: <strong class="text-mist-950 dark:text-white">.md</strong>,
              <strong class="text-mist-950 dark:text-white">.markdown</strong>, and
              <strong class="text-mist-950 dark:text-white">.txt</strong>. Anything you can
              save as plain text or markdown works — meeting notes, drafts, board updates.
            </p>

            <div class="mt-4 max-w-md">
              <%= render "shared/demo_browser_frame" do %>
                <div class="w-full rounded-md bg-white dark:bg-mist-900 p-4">
                  <div class="flex items-center gap-3">
                    <svg class="size-8 shrink-0 text-mist-400 dark:text-mist-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M5.625 1.5H9a3.75 3.75 0 0 1 3.75 3.75v1.875c0 1.036.84 1.875 1.875 1.875H16.5a3.75 3.75 0 0 1 3.75 3.75v7.875c0 1.035-.84 1.875-1.875 1.875H5.625a1.875 1.875 0 0 1-1.875-1.875V3.375c0-1.036.84-1.875 1.875-1.875Z" clip-rule="evenodd" />
                      <path d="M14.25 5.25a5.23 5.23 0 0 0-1.279-3.434 9.768 9.768 0 0 1 6.963 6.963A5.23 5.23 0 0 0 16.5 7.5h-1.875a.375.375 0 0 1-.375-.375V5.25Z" />
                    </svg>
                    <div class="min-w-0">
                      <p class="truncate text-sm font-medium text-mist-950 dark:text-white">Q3-board-update.md</p>
                      <p class="text-xs text-mist-500 dark:text-mist-400">12 KB</p>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </article>
      </li>

      <%# Step 2 --------------------------------------------------------- %>
      <li id="step-2" data-scroll-spy-target="step" data-step="2" class="scroll-mt-24">
        <article class="grid grid-cols-[auto_1fr] gap-x-4">
          <%= render "pages/splitting_step_badge", n: 2 %>
          <div class="min-w-0">
            <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
              Open the Upload File tab
            </h3>
            <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              Click <strong class="text-mist-950 dark:text-white">New Episode</strong> in the
              navigation, then switch to the <strong class="text-mist-950 dark:text-white">Upload File</strong>
              tab. The button at the bottom of this guide takes you straight there.
            </p>

            <div class="mt-4 max-w-md">
              <%= render "shared/demo_browser_frame" do %>
                <div class="w-full rounded-md bg-white dark:bg-mist-900 p-4">
                  <nav class="flex gap-6 border-b border-mist-200 dark:border-mist-700">
                    <span class="pb-2 text-sm font-medium text-mist-500 dark:text-mist-400">From URL</span>
                    <span class="pb-2 text-sm font-medium text-mist-500 dark:text-mist-400">Paste Text</span>
                    <span class="border-b-2 border-mist-950 dark:border-white pb-2 text-sm font-medium text-mist-950 dark:text-white">Upload File</span>
                  </nav>
                  <div class="mt-4 space-y-3">
                    <div class="h-3 w-1/3 rounded bg-mist-100 dark:bg-mist-800"></div>
                    <div class="h-24 w-full rounded-md border-2 border-dashed border-mist-200 dark:border-mist-700 bg-mist-50 dark:bg-mist-800/50"></div>
                    <button class="rounded-md bg-mist-950 dark:bg-white px-4 py-2 text-sm font-medium text-white dark:text-mist-950">
                      Create Episode
                    </button>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </article>
      </li>

      <%# Step 3 --------------------------------------------------------- %>
      <li id="step-3" data-scroll-spy-target="step" data-step="3" class="scroll-mt-24">
        <article class="grid grid-cols-[auto_1fr] gap-x-4">
          <%= render "pages/splitting_step_badge", n: 3 %>
          <div class="min-w-0">
            <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
              Drop in your file
            </h3>
            <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              Drag and drop your file into the dropzone, or click it to open a file
              picker. The filename appears once it's attached.
            </p>

            <div class="mt-4 max-w-md">
              <%= render "shared/demo_browser_frame" do %>
                <div class="w-full rounded-md bg-white dark:bg-mist-900 p-4">
                  <div class="flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-mist-300 dark:border-mist-700 px-6 py-10">
                    <svg class="size-10 text-mist-300 dark:text-mist-600" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M5.625 1.5H9a3.75 3.75 0 0 1 3.75 3.75v1.875c0 1.036.84 1.875 1.875 1.875H16.5a3.75 3.75 0 0 1 3.75 3.75v7.875c0 1.035-.84 1.875-1.875 1.875H5.625a1.875 1.875 0 0 1-1.875-1.875V3.375c0-1.036.84-1.875 1.875-1.875Zm6.905 9.97a.75.75 0 0 0-1.06 0l-3 3a.75.75 0 1 0 1.06 1.06l1.72-1.72V18a.75.75 0 0 0 1.5 0v-4.19l1.72 1.72a.75.75 0 1 0 1.06-1.06l-3-3Z" clip-rule="evenodd" />
                      <path d="M14.25 5.25a5.23 5.23 0 0 0-1.279-3.434 9.768 9.768 0 0 1 6.963 6.963A5.23 5.23 0 0 0 16.5 7.5h-1.875a.375.375 0 0 1-.375-.375V5.25Z" />
                    </svg>
                    <p class="mt-3 text-sm/6 text-mist-500 dark:text-mist-400">Drop file here or click to browse</p>
                    <p class="mt-1 text-xs text-mist-400 dark:text-mist-500">.md or .txt</p>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </article>
      </li>

      <%# Step 4 --------------------------------------------------------- %>
      <li id="step-4" data-scroll-spy-target="step" data-step="4" class="scroll-mt-24">
        <article class="grid grid-cols-[auto_1fr] gap-x-4">
          <%= render "pages/splitting_step_badge", n: 4 %>
          <div class="min-w-0">
            <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
              Episode appears in your feed
            </h3>
            <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              Submit the form. Your episode shows up on the list right away and
              finishes processing in about a minute, depending on the file's length.
            </p>

            <div class="mt-4 max-w-md">
              <%= render "shared/demo_browser_frame" do %>
                <div class="w-full rounded-md bg-white dark:bg-mist-900 p-4">
                  <ul role="list" class="divide-y divide-mist-950/5 dark:divide-mist-50/5">
                    <li class="flex items-center gap-3 py-2">
                      <span class="flex size-2 shrink-0 rounded-full bg-green-500"></span>
                      <p class="truncate text-sm font-medium text-mist-950 dark:text-white">Q3 Board Update</p>
                      <span class="ml-auto text-xs text-mist-500 dark:text-mist-400 tabular-nums">3:18</span>
                    </li>
                  </ul>
                </div>
              <% end %>
            </div>
          </div>
        </article>
      </li>
    </ol>

    <%# CTAs ------------------------------------------------------------- %>
    <div class="mt-12 flex flex-col gap-3 border-t border-mist-950/5 dark:border-mist-50/5 pt-8 sm:flex-row">
      <%= link_to "Open the upload form", new_episode_path(source: "file"),
                  class: "inline-flex items-center justify-center rounded-md bg-mist-950 dark:bg-white px-4 py-2 text-sm font-medium text-white dark:text-mist-950 hover:bg-mist-800 dark:hover:bg-mist-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-mist-950 dark:focus-visible:outline-white" %>
      <%= link_to "Back to your episodes", episodes_path,
                  class: "inline-flex items-center justify-center rounded-md border border-mist-200 dark:border-mist-700 px-4 py-2 text-sm font-medium text-mist-950 dark:text-white hover:bg-mist-100 dark:hover:bg-mist-800" %>
    </div>
  </section>
<% end %>
