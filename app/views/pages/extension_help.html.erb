<% steps = [
     { n: 1, label: "Install" },
     { n: 2, label: "Connect" },
     { n: 3, label: "Click icon" },
     { n: 4, label: "Wait for episode" }
   ] %>
<% content_for :right_toc do %>
  <%= render "shared/help_right_toc", steps: steps %>
<% end %>
<%= render layout: "shared/help_layout", locals: { current: :extension_help } do %>

  <section class="pb-12">
    <%# Page intro -------------------------------------------------------- %>
    <h2 class="max-w-[40ch] text-lg/8 font-semibold text-balance text-mist-950 dark:text-white">
      Browser extension
    </h2>
    <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
      Send any article to your podcast feed with one click from your browser
      toolbar.
    </p>

    <%# Step body. Active state in the right-rail ToC is driven by         %>
    <%# aria-current="step", set by the scroll-spy controller mounted on   %>
    <%# the help_layout root (see shared/_help_layout.html.erb).           %>
    <ol role="list" class="mt-10 space-y-12">

      <%# Step 1 --------------------------------------------------------- %>
      <li id="step-1" data-scroll-spy-target="step" data-step="1" class="scroll-mt-24">
        <article class="grid grid-cols-[auto_1fr] gap-x-4">
          <%= render "pages/splitting_step_badge", n: 1 %>
          <div class="min-w-0">
            <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
              Install from the Chrome Web Store
            </h3>
            <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              Click <strong class="text-mist-950 dark:text-white">install</strong>,
              then pin PodRead to your toolbar so it's one click away.
            </p>

            <div class="mt-4 max-w-md">
              <%= render "shared/demo_browser_frame" do %>
                <div class="w-full rounded-md bg-white dark:bg-mist-900 p-4 space-y-3">
                  <div class="flex items-center gap-3">
                    <div class="flex size-10 shrink-0 items-center justify-center rounded-md bg-mist-100 dark:bg-mist-800 text-base font-semibold text-mist-950 dark:text-white">
                      P
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="truncate text-sm font-medium text-mist-950 dark:text-white">PodRead Extension</p>
                      <p class="truncate text-xs text-mist-500 dark:text-mist-400">chromewebstore.google.com</p>
                    </div>
                  </div>
                  <button class="w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white">
                    Add to Chrome
                  </button>
                </div>
              <% end %>
            </div>
          </div>
        </article>
      </li>

      <%# Step 2 --------------------------------------------------------- %>
      <li id="step-2" data-scroll-spy-target="step" data-step="2" class="scroll-mt-24">
        <article class="grid grid-cols-[auto_1fr] gap-x-4">
          <%= render "pages/splitting_step_badge", n: 2 %>
          <div class="min-w-0">
            <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
              Connect your account
            </h3>
            <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              The first click on the extension icon redirects you to PodRead to
              authorize. After that, the extension knows where to send articles.
            </p>

            <div class="mt-4 max-w-md">
              <%= render "shared/demo_browser_frame" do %>
                <div class="w-full rounded-md bg-white dark:bg-mist-900 p-4 space-y-3">
                  <p class="text-sm font-semibold text-mist-950 dark:text-white">Authorize PodRead</p>
                  <p class="text-sm/6 text-mist-700 dark:text-mist-400">
                    Allow the extension to send articles to your podcast feed.
                  </p>
                  <button class="rounded-md bg-mist-950 dark:bg-white px-4 py-2 text-sm font-medium text-white dark:text-mist-950">
                    Authorize
                  </button>
                </div>
              <% end %>
            </div>
          </div>
        </article>
      </li>

      <%# Step 3 --------------------------------------------------------- %>
      <li id="step-3" data-scroll-spy-target="step" data-step="3" class="scroll-mt-24">
        <article class="grid grid-cols-[auto_1fr] gap-x-4">
          <%= render "pages/splitting_step_badge", n: 3 %>
          <div class="min-w-0">
            <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
              Click the icon on any article
            </h3>
            <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              Open the article you want to listen to and click the PodRead icon
              in your toolbar. A green checkmark on the icon means the article
              was sent.
            </p>

            <div class="mt-4 max-w-md">
              <%= render "shared/demo_browser_frame" do %>
                <div class="w-full rounded-md bg-white dark:bg-mist-900 p-3">
                  <div class="flex items-center justify-end gap-2">
                    <div class="relative">
                      <div class="flex size-8 items-center justify-center rounded-md bg-mist-100 dark:bg-mist-800 text-sm font-semibold text-mist-950 dark:text-white">
                        P
                      </div>
                      <span class="absolute -bottom-1 -right-1 inline-flex size-4 items-center justify-center rounded bg-green-600 text-[10px] font-bold text-white">&#x2713;</span>
                    </div>
                  </div>
                  <p class="mt-3 text-xs text-mist-500 dark:text-mist-400">Article sent to your feed</p>
                </div>
              <% end %>
            </div>
          </div>
        </article>
      </li>

      <%# Step 4 --------------------------------------------------------- %>
      <li id="step-4" data-scroll-spy-target="step" data-step="4" class="scroll-mt-24">
        <article class="grid grid-cols-[auto_1fr] gap-x-4">
          <%= render "pages/splitting_step_badge", n: 4 %>
          <div class="min-w-0">
            <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
              Episode appears in your feed
            </h3>
            <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              Once you click the extension icon, audio generation kicks off
              and will take a few minutes. After that, the episode publishes
              to your personal podcast feed and your podcast app picks it up
              on its next refresh. An episode can show up in your podcast app
              quickly or take a while, but the audio will be available on
              PodRead in a few minutes.
            </p>

            <div class="mt-4 max-w-md">
              <%= render "shared/demo_browser_frame" do %>
                <div class="w-full rounded-md bg-white dark:bg-mist-900 p-4">
                  <ul role="list" class="divide-y divide-mist-950/5 dark:divide-mist-50/5">
                    <li class="flex items-center gap-3 py-2">
                      <span class="flex size-2 shrink-0 rounded-full bg-green-500"></span>
                      <p class="truncate text-sm font-medium text-mist-950 dark:text-white">The article you just sent</p>
                      <span class="ml-auto text-xs text-mist-500 dark:text-mist-400 tabular-nums">7:18</span>
                    </li>
                  </ul>
                </div>
              <% end %>
            </div>
          </div>
        </article>
      </li>
    </ol>

    <%# CTAs ------------------------------------------------------------- %>
    <div class="mt-12 flex flex-col gap-3 border-t border-mist-950/5 dark:border-mist-50/5 pt-8 sm:flex-row">
      <%= link_to "Get the extension", AppConfig::Extension::CHROME_WEB_STORE_URL,
                  target: "_blank", rel: "noopener",
                  class: "inline-flex items-center justify-center rounded-md bg-mist-950 dark:bg-white px-4 py-2 text-sm font-medium text-white dark:text-mist-950 hover:bg-mist-800 dark:hover:bg-mist-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-mist-950 dark:focus-visible:outline-white" %>
      <%= link_to "Back to your episodes", episodes_path,
                  class: "inline-flex items-center justify-center rounded-md border border-mist-200 dark:border-mist-700 px-4 py-2 text-sm font-medium text-mist-950 dark:text-white hover:bg-mist-100 dark:hover:bg-mist-800" %>
    </div>

    <%# More info ------------------------------------------------------- %>
    <div class="mt-12 space-y-10">

      <%# Icon badge states -------------------------------------------- %>
      <div>
        <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
          Icon badge states
        </h3>
        <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
          The extension shows a small badge on the icon to indicate status.
        </p>
        <ul role="list" class="mt-4 space-y-3 text-sm/6 text-mist-700 dark:text-mist-400">
          <li class="flex items-center gap-3">
            <span class="inline-flex size-8 items-center justify-center rounded bg-mist-100 dark:bg-mist-800 text-sm font-medium text-mist-500 dark:text-mist-400">--</span>
            <span><strong class="text-mist-950 dark:text-white">No badge</strong> &mdash; ready to send an article</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="inline-flex size-8 items-center justify-center rounded bg-blue-600 text-sm font-bold text-white">...</span>
            <span><strong class="text-mist-950 dark:text-white">Blue dots</strong> &mdash; sending article</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="inline-flex size-8 items-center justify-center rounded bg-green-600 text-sm font-bold text-white">&#x2713;</span>
            <span><strong class="text-mist-950 dark:text-white">Green checkmark</strong> &mdash; article sent to your feed</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="inline-flex size-8 items-center justify-center rounded bg-red-600 text-sm font-bold text-white">!</span>
            <span><strong class="text-mist-950 dark:text-white">Red exclamation</strong> &mdash; something went wrong (page may not be an article)</span>
          </li>
        </ul>
      </div>

      <%# Disconnecting ------------------------------------------------ %>
      <div>
        <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
          Disconnecting
        </h3>
        <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
          Two ways to disconnect the extension from your account:
        </p>
        <ul role="list" class="mt-3 max-w-[60ch] list-disc list-inside space-y-2 text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
          <li>
            <strong class="text-mist-950 dark:text-white">Right-click</strong>
            the extension icon and select
            <strong class="text-mist-950 dark:text-white">Disconnect from PodRead</strong>.
          </li>
          <li>
            Disconnect from your
            <%= link_to "extension settings", settings_extensions_path, class: "text-mist-950 underline dark:text-white" %>.
          </li>
        </ul>
      </div>

      <%# Troubleshooting ---------------------------------------------- %>
      <div>
        <h3 class="text-base font-semibold text-balance text-mist-950 dark:text-white">
          Troubleshooting
        </h3>

        <div class="mt-4 divide-y divide-mist-950/5 dark:divide-mist-50/5 border-y border-mist-950/5 dark:border-mist-50/5">
          <details class="group py-3">
            <summary class="cursor-pointer list-none text-sm font-medium text-mist-950 dark:text-white marker:hidden [&amp;::-webkit-details-marker]:hidden flex items-center justify-between gap-3">
              <span>"This page does not appear to be an article"</span>
              <span aria-hidden="true" class="text-mist-500 transition group-open:rotate-180">&#x25BE;</span>
            </summary>
            <div class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              <p>The extension works best on article pages with substantial text content. It may not work on:</p>
              <ul role="list" class="mt-2 list-disc list-inside space-y-1">
                <li>Home pages or index pages</li>
                <li>Pages with mostly images or video</li>
                <li>Pages behind paywalls or login walls</li>
                <li>PDFs or non-HTML content</li>
              </ul>
            </div>
          </details>

          <details class="group py-3">
            <summary class="cursor-pointer list-none text-sm font-medium text-mist-950 dark:text-white marker:hidden [&amp;::-webkit-details-marker]:hidden flex items-center justify-between gap-3">
              <span>Extension shows error state</span>
              <span aria-hidden="true" class="text-mist-500 transition group-open:rotate-180">&#x25BE;</span>
            </summary>
            <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              Try refreshing the page and clicking the icon again. If the problem
              persists, the page content may not be extractable.
            </p>
          </details>

          <details class="group py-3">
            <summary class="cursor-pointer list-none text-sm font-medium text-mist-950 dark:text-white marker:hidden [&amp;::-webkit-details-marker]:hidden flex items-center justify-between gap-3">
              <span>Need to reconnect?</span>
              <span aria-hidden="true" class="text-mist-500 transition group-open:rotate-180">&#x25BE;</span>
            </summary>
            <p class="mt-2 max-w-[60ch] text-sm/6 text-pretty text-mist-700 dark:text-mist-400">
              If you're logged out or need to reconnect, just click the extension
              icon &mdash; you'll be redirected to the connect page automatically.
            </p>
          </details>
        </div>
      </div>
    </div>
  </section>
<% end %>
