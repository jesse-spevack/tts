<div data-controller="episodes-live" data-episodes-live-podcast-id-value="<%= @podcast.id %>"></div>

<div>
  <div class="mb-8">
    <h1 class="font-display text-2xl tracking-tight text-mist-950 dark:text-white">Episodes</h1>
    <p class="mt-2 text-sm text-mist-500 dark:text-mist-400 flex items-center gap-2">
      RSS Feed: <span class="text-mist-950 dark:text-white break-all"><%= demo_mode? ? @podcast.feed_url.sub(@podcast.podcast_id, '•••••••••') : @podcast.feed_url %></span>
      <%= render "shared/clipboard_button",
        content: @podcast.feed_url,
        title: "Copy RSS feed URL",
        icon: "copy",
        button_class: "text-mist-500 dark:text-mist-400 hover:text-mist-950 dark:hover:text-white transition-colors cursor-pointer flex-shrink-0"
      %>
    </p>
  </div>

  <%= form_with url: episodes_path, method: :get, data: { controller: "search", turbo_frame: "episodes_list", turbo_action: "advance" } do |f| %>
    <%= f.search_field :q, value: @query, placeholder: "Search episodes...", class: input_classes, data: { search_target: "input", action: "input->search#search" }, autocomplete: "off" %>
  <% end %>

  <%= turbo_frame_tag "episodes_list" do %>
    <%= render "episodes_list" %>
  <% end %>
</div>
