<% content_for :title, "MPP API — PodRead" %>

<div class="relative isolate" data-controller="copy-docs">
  <!-- Background tint -->
  <div class="absolute inset-x-0 top-0 -z-10 h-[480px] bg-linear-to-b from-mist-50 to-transparent dark:from-mist-900/40"></div>

  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-x-16 px-6 lg:px-10 xl:grid-cols-[minmax(0,1fr)_220px]">
    <!-- Main column -->
    <div class="min-w-0 pb-24" data-copy-docs-target="source">
      <!-- Docs nav -->
      <nav class="pt-8 text-sm" data-copy-skip>
        <ul class="flex flex-wrap items-center gap-x-6 gap-y-2 text-mist-500 dark:text-mist-400">
          <li><%= link_to "Authentication", docs_authentication_path, class: "hover:text-mist-950 dark:hover:text-white" %></li>
          <li><%= link_to "Episodes", docs_episodes_path, class: "hover:text-mist-950 dark:hover:text-white" %></li>
          <li class="font-medium text-mist-950 dark:text-white" aria-current="page">Machine Payments</li>
        </ul>
      </nav>
      <!-- Hero -->
      <header class="pt-8 pb-16">
        <div class="flex items-center gap-x-3 text-sm">
          <span class="inline-flex items-center gap-x-1.5 rounded-full bg-mist-900 py-1 pl-1 pr-2.5 font-mono text-xs text-white dark:bg-mist-100 dark:text-mist-900">
            <span class="size-1.5 rounded-full bg-emerald-400 dark:bg-emerald-500"></span>
            Public API
          </span>
          <%= render "docs/copy_for_llm_button" %>
        </div>
        <div class="mt-3 text-sm text-mist-500 dark:text-mist-400">
          <a href="http://mpp.dev/" class="underline decoration-mist-300 underline-offset-4 hover:decoration-mist-700 dark:decoration-mist-700 dark:hover:decoration-mist-300">Machine Payments Protocol</a>
        </div>
        <h1 class="mt-6 font-serif text-5xl tracking-tight text-balance text-mist-950 sm:text-6xl dark:text-white">
          Turn any text into audio — pay per narration.
        </h1>
        <p class="mt-6 max-w-[65ch] text-pretty text-lg leading-8 text-mist-700 dark:text-mist-300">
          PodRead converts articles and text into audio. Machine Payments Protocol (MPP) lets you pay per narration with on-chain stablecoin on the Tempo network — no PodRead account required. Pricing is tiered: Standard voices cost 75¢, Premium voices cost $1.50. Authenticated users whose free tier is exhausted can also pay via MPP instead of subscribing.
        </p>

        <!-- Fact row: two-tier price table + meta -->
        <div class="mt-10 grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto]">
          <div class="overflow-hidden rounded-lg ring-1 ring-mist-200 dark:ring-white/10">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-mist-50 dark:bg-mist-900/50">
                  <th class="py-2.5 pl-4 pr-6 text-left text-xs font-medium text-mist-500 dark:text-mist-400">Tier</th>
                  <th class="py-2.5 pr-6 text-left text-xs font-medium text-mist-500 dark:text-mist-400">Price</th>
                  <th class="py-2.5 pr-4 text-left text-xs font-medium text-mist-500 dark:text-mist-400">Voices</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-mist-200 dark:divide-mist-800">
                <tr>
                  <td class="py-3 pl-4 pr-6">
                    <span class="inline-flex items-center rounded-full bg-mist-100 px-2.5 py-0.5 text-xs font-medium text-mist-700 dark:bg-mist-800 dark:text-mist-300">Standard</span>
                  </td>
                  <td class="py-3 pr-6 font-serif text-xl tracking-tight text-mist-950 tabular-nums dark:text-white">$0.75</td>
                  <td class="py-3 pr-4 font-mono text-xs text-mist-700 dark:text-mist-300">wren, felix, sloane, archer, gemma, hugo, quinn, theo</td>
                </tr>
                <tr>
                  <td class="py-3 pl-4 pr-6">
                    <span class="inline-flex items-center rounded-full bg-mist-900 px-2.5 py-0.5 text-xs font-medium text-white dark:bg-mist-100 dark:text-mist-900">Premium</span>
                  </td>
                  <td class="py-3 pr-6 font-serif text-xl tracking-tight text-mist-950 tabular-nums dark:text-white">$1.50</td>
                  <td class="py-3 pr-4 font-mono text-xs text-mist-700 dark:text-mist-300">elara, callum, lark, nash</td>
                </tr>
              </tbody>
            </table>
          </div>
          <dl class="grid grid-cols-3 gap-6 self-start lg:grid-cols-1 lg:gap-4">
            <div class="border-l border-mist-300 pl-4 dark:border-mist-700">
              <dt class="text-xs font-medium text-mist-500 dark:text-mist-400">Currency</dt>
              <dd class="mt-1 font-serif text-xl tracking-tight text-mist-950 dark:text-white">USDC</dd>
            </div>
            <div class="border-l border-mist-300 pl-4 dark:border-mist-700">
              <dt class="text-xs font-medium text-mist-500 dark:text-mist-400">Network</dt>
              <dd class="mt-1 font-serif text-xl tracking-tight text-mist-950 dark:text-white">Tempo</dd>
            </div>
            <div class="border-l border-mist-300 pl-4 dark:border-mist-700">
              <dt class="text-xs font-medium text-mist-500 dark:text-mist-400">TTL</dt>
              <dd class="mt-1 font-serif text-xl tracking-tight text-mist-950 tabular-nums dark:text-white">24 h</dd>
            </div>
          </dl>
        </div>
      </header>

      <!-- Quick Start -->
      <section id="quickstart" class="scroll-mt-8 pt-12">
        <h2 class="font-serif text-3xl tracking-tight text-mist-950 dark:text-white">Quick start</h2>
        <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
          The fastest path uses the <code class="ic">mppx</code> CLI. It handles the 402 challenge, on-chain payment, and credential construction automatically.
        </p>

        <h3 class="mt-8 font-serif text-xl tracking-tight text-mist-950 dark:text-white">Pay podread.app on mainnet</h3>
        <p class="mt-3 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
          Call the hosted API directly. Requires USDC.e on Tempo mainnet — see <a href="#funding" class="underline decoration-mist-300 underline-offset-4 hover:decoration-mist-700 dark:decoration-mist-700 dark:hover:decoration-mist-300">Funding on mainnet</a> below.
        </p>

        <figure class="mt-4 overflow-hidden rounded-xl bg-mist-950 shadow-lg ring-1 ring-mist-900/10 dark:shadow-none dark:ring-white/10">
          <figcaption class="flex items-center justify-between border-b border-white/10 px-5 py-2.5 text-xs">
            <span class="font-mono text-mist-400">bash</span>
            <span class="text-mist-500">production — mainnet</span>
          </figcaption>
          <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:bash, <<~BASH
            # Create an MPP wallet (one-time setup) and fund it with USDC.e on Tempo mainnet — see below
            npx mppx account create

            # Pay a narration on podread.app — mppx handles the 402 flow automatically
            npx mppx https://podread.app/api/v1/mpp/narrations \\
              -X POST -H "Content-Type: application/json" \\
              -d '{"source_type":"url","url":"https://www.worksinprogress.news/p/the-secret-behind-japans-railways"}' \\
              --rpc-url https://rpc.tempo.xyz
          BASH
          ) %></code></pre>
        </figure>

        <h3 id="funding" class="mt-10 scroll-mt-8 font-serif text-xl tracking-tight text-mist-950 dark:text-white">Funding on mainnet</h3>
        <p class="mt-3 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
          podread.app accepts payment in <strong class="font-semibold text-mist-950 dark:text-white">USDC.e</strong> (Stargate-bridged USDC) on Tempo at <code class="ic">0x20c0…b9537d11c60e8b50</code>. Native USDC does not exist on Tempo today.
        </p>
        <ol class="ml-6 mt-3 list-decimal space-y-2 text-mist-700 dark:text-mist-300">
          <li>Hold USDC on a chain Stargate supports (Base, Arbitrum, Optimism, and Polygon all work well).</li>
          <li>Bridge to Tempo via <a href="https://stargate.finance/bridge" class="underline decoration-mist-300 underline-offset-4 hover:decoration-mist-700 dark:decoration-mist-700 dark:hover:decoration-mist-300">stargate.finance/bridge</a> — USDC → USDC.e.</li>
          <li>Send the bridged USDC.e to the address printed by <code class="ic">npx mppx account create</code>.</li>
        </ol>
        <p class="mt-3 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
          Tempo has no native gas token — gas is paid in USDC.e itself, so leave a small buffer above the narration price. About <strong class="font-semibold text-mist-950 dark:text-white">$1</strong> covers several requests.
        </p>

        <h3 class="mt-10 font-serif text-xl tracking-tight text-mist-950 dark:text-white">Try it on testnet</h3>
        <p class="mt-3 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
          Run a self-hosted PodRead instance against Tempo's Moderato testnet. Faucet-dispensed pathUSD — no real money changes hands.
        </p>

        <figure class="mt-4 overflow-hidden rounded-xl bg-mist-950 shadow-lg ring-1 ring-mist-900/10 dark:shadow-none dark:ring-white/10">
          <figcaption class="flex items-center justify-between border-b border-white/10 px-5 py-2.5 text-xs">
            <span class="font-mono text-mist-400">bash</span>
            <span class="text-mist-500">self-hosted — testnet</span>
          </figcaption>
          <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:bash, <<~BASH
            # Create an MPP wallet (one-time setup)
            npx mppx account create

            # Fund the wallet with testnet pathUSD
            npx mppx account fund --rpc-url https://rpc.moderato.tempo.xyz

            # Pay a narration on your local server
            npx mppx http://your-podread-host/api/v1/mpp/narrations \\
              -X POST -H "Content-Type: application/json" \\
              -d '{"source_type":"url","url":"https://www.worksinprogress.news/p/the-secret-behind-japans-railways"}' \\
              --rpc-url https://rpc.moderato.tempo.xyz
          BASH
          ) %></code></pre>
        </figure>

        <p class="mt-6 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
          Both examples hit <code class="ic">POST /api/v1/mpp/narrations</code> anonymously and return a <code class="ic">nar_</code>-prefixed Narration id you can poll at <code class="ic">GET /api/v1/mpp/narrations/:id</code>. Authenticated users who want to pay per episode hit <code class="ic">POST /api/v1/mpp/episodes</code> instead and get an <code class="ic">ep_</code>-prefixed Episode attached to their primary podcast. See <a href="#auth-paths" class="underline decoration-mist-300 underline-offset-4 hover:decoration-mist-700 dark:decoration-mist-700 dark:hover:decoration-mist-300">Authentication paths</a> for the full matrix.
        </p>
        <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
          Omitting <code class="ic">voice</code> defaults to <code class="ic">felix</code> (Standard, 75¢). Request a Premium voice (<code class="ic">elara</code>, <code class="ic">callum</code>, <code class="ic">lark</code>, <code class="ic">nash</code>) and the 402 challenge arrives at $1.50 instead — see <a href="#pricing" class="underline decoration-mist-300 underline-offset-4 hover:decoration-mist-700 dark:decoration-mist-700 dark:hover:decoration-mist-300">Pricing</a>.
        </p>
      </section>

      <!-- Protocol Flow -->
      <section id="protocol" class="scroll-mt-8 pt-20">
        <h2 class="font-serif text-3xl tracking-tight text-mist-950 dark:text-white">Protocol flow</h2>
        <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">Five steps: request, receive challenge, pay, retry with credential, poll for audio.</p>

        <ol role="list" class="mt-10 space-y-14">
          <li class="relative">
            <div class="flex items-baseline gap-x-4">
              <span class="font-mono text-xs text-mist-500 tabular-nums dark:text-mist-400">Step 1</span>
              <h3 class="font-serif text-xl text-mist-950 dark:text-white">Request episode creation</h3>
            </div>
            <figure class="mt-4 overflow-hidden rounded-xl bg-mist-950 ring-1 ring-mist-900/10 dark:ring-white/10">
              <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:bash, <<~BASH
                curl -X POST https://podread.app/api/v1/mpp/narrations \\
                  -H "Content-Type: application/json" \\
                  -d '{"source_type":"url","url":"https://www.worksinprogress.news/p/the-secret-behind-japans-railways"}'
              BASH
              ) %></code></pre>
            </figure>
            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
              Without a Payment credential, the server returns <strong class="font-semibold text-mist-950 dark:text-white">402 Payment Required</strong>. The amount reflects the resolved voice's tier — 75 cents for Standard (the example below), 150 cents if the request asked for a Premium voice.
            </p>

            <div class="mt-4 grid gap-4 lg:grid-cols-2">
              <figure class="overflow-hidden rounded-xl bg-mist-950 ring-1 ring-mist-900/10 dark:ring-white/10">
                <figcaption class="border-b border-white/10 px-5 py-2 font-mono text-xs text-mist-400">response headers</figcaption>
                <pre class="overflow-x-auto p-5 font-mono text-[12px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:http, <<~HTTP
                  HTTP/1.1 402 Payment Required
                  WWW-Authenticate: Payment
                    id="a1b2c3d4e5f6…",
                    realm="podread.app",
                    method="tempo",
                    intent="charge",
                    request="<base64>",
                    expires="2026-04-10T12:05:00+00:00"
                HTTP
                ) %></code></pre>
              </figure>
              <figure class="overflow-hidden rounded-xl bg-mist-950 ring-1 ring-mist-900/10 dark:ring-white/10">
                <figcaption class="border-b border-white/10 px-5 py-2 font-mono text-xs text-mist-400">response body</figcaption>
                <pre class="overflow-x-auto p-5 font-mono text-[12px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:json, <<~JSON
                  {
                    "error": "Payment required",
                    "challenge": {
                      "id": "a1b2c3d4e5f6…",
                      "amount": 75,
                      "currency": "usd",
                      "methods": ["tempo"],
                      "realm": "podread.app",
                      "expires": "2026-04-10T12:05:00+00:00",
                      "deposit_address": "0x1234abcd…"
                    }
                  }
                JSON
                ) %></code></pre>
              </figure>
            </div>

            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">Fields in the outer challenge object:</p>

            <% challenge_fields = [
              { name: "id", type: "string",
                description: %(HMAC-SHA256 hex over <code class="ic">realm|method|intent|request|expires</code> signed with the server's secret — doubles as challenge identifier and tamper-check. Clients should echo it back unchanged in the credential.).html_safe },
              { name: "amount", type: "integer",
                description: %(In <strong class="font-semibold text-mist-950 dark:text-white">cents</strong> (75 = $0.75 for Standard, 150 = $1.50 for Premium). Distinct from <code class="ic">request.amount</code> below, which is in token base units.).html_safe },
              { name: "currency", type: "string",
                description: %(The <strong class="font-semibold text-mist-950 dark:text-white">ISO 4217 code</strong> (<code class="ic">"usd"</code>). Distinct from <code class="ic">request.currency</code> below, which is an ERC-20 contract address.).html_safe },
              { name: "request", type: "string",
                description: %(<strong class="font-semibold text-mist-950 dark:text-white">Standard base64</strong> (with padding, <code class="ic">+</code>/<code class="ic">/</code> alphabet) — not base64url. Decodes to the object below.).html_safe }
            ] %>

            <%= render "docs/param_table", rows: challenge_fields %>

            <figure class="mt-6 overflow-hidden rounded-xl bg-mist-950 ring-1 ring-mist-900/10 dark:ring-white/10">
              <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:json, <<~JSON
                {
                  "amount": "750000",
                  "currency": "0x20c000000000000000000000b9537d11c60e8b50",
                  "recipient": "0x1234abcd…"
                }
              JSON
              ) %></code></pre>
            </figure>

            <% decoded_request_fields = [
              { name: "amount", type: "string",
                description: %(Token base units — the stablecoin has 6 decimals, so <span class="font-mono tabular-nums">750000</span> = $0.75 (Standard) and <span class="font-mono tabular-nums">1500000</span> = $1.50 (Premium).).html_safe },
              { name: "currency", type: "string",
                description: %(The ERC-20 stablecoin contract address on Tempo. On <strong class="font-semibold text-mist-950 dark:text-white">podread.app</strong> this is USDC.e (Stargate-bridged USDC) at <code class="ic">0x20c0…b9537d11c60e8b50</code>; self-hosted testnet deployments default to pathUSD at <code class="ic">0x20c0…0000</code>.).html_safe },
              { name: "recipient", type: "string",
                description: %(The one-time Stripe-provisioned deposit address.).html_safe }
            ] %>

            <%= render "docs/param_table", rows: decoded_request_fields %>
          </li>

          <li class="relative">
            <div class="flex items-baseline gap-x-4">
              <span class="font-mono text-xs text-mist-500 tabular-nums dark:text-mist-400">Step 2</span>
              <h3 class="font-serif text-xl text-mist-950 dark:text-white">Pay</h3>
            </div>
            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">Send a USDC transfer on the Tempo network to the <code class="ic">deposit_address</code> from the challenge. The transfer must be:</p>
            <ul role="list" class="mt-4 space-y-1.5 text-mist-700 dark:text-mist-300">
              <li>To the exact <code class="ic">deposit_address</code> returned in the 402 response</li>
              <li>For the exact <code class="ic">request.amount</code> from the challenge — <span class="font-mono tabular-nums">750000</span> base units for Standard voices ($0.75), <span class="font-mono tabular-nums">1500000</span> for Premium ($1.50)</li>
              <li>Of the stablecoin whose contract address is echoed in the challenge's <code class="ic">request.currency</code> field — on <strong class="font-semibold text-mist-950 dark:text-white">podread.app</strong> that is USDC.e (Stargate-bridged USDC) at <code class="ic">0x20c0…b9537d11c60e8b50</code></li>
              <li>Completed before the challenge <code class="ic">expires</code> timestamp</li>
            </ul>
          </li>

          <li class="relative">
            <div class="flex items-baseline gap-x-4">
              <span class="font-mono text-xs text-mist-500 tabular-nums dark:text-mist-400">Step 3</span>
              <h3 class="font-serif text-xl text-mist-950 dark:text-white">Retry with credential</h3>
            </div>
            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">Construct a credential and retry the original request with it in the <code class="ic">Authorization</code> header. The credential is a <strong class="font-semibold text-mist-950 dark:text-white">base64url-encoded</strong> JSON object:</p>
            <figure class="mt-4 overflow-hidden rounded-xl bg-mist-950 ring-1 ring-mist-900/10 dark:ring-white/10">
              <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:json, <<~JSON
                {
                  "challenge": {
                    "id": "a1b2c3d4e5f6…",
                    "realm": "podread.app",
                    "method": "tempo",
                    "intent": "charge",
                    "request": "<base64-encoded-request-json>",
                    "expires": "2026-04-10T12:05:00+00:00"
                  },
                  "payload": {
                    "hash": "0xabc123…"
                  }
                }
              JSON
              ) %></code></pre>
            </figure>
            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
              The <code class="ic">payload</code> contains either <code class="ic">hash</code> (tx hash of an already-submitted transfer, shown above) or <code class="ic">signature</code> (a signed raw tx the server will submit on your behalf via <code class="ic">eth_sendRawTransaction</code>). The signature must be an RLP-encoded signed Ethereum transaction, hex-prefixed — any valid transaction type (legacy, EIP-2930, EIP-1559) is accepted as long as it transfers the right amount of the stablecoin (USDC.e on <strong class="font-semibold text-mist-950 dark:text-white">podread.app</strong>) to the challenge's deposit address.
            </p>
            <figure class="mt-4 overflow-hidden rounded-xl bg-mist-950 ring-1 ring-mist-900/10 dark:ring-white/10">
              <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:json, <<~JSON
                {
                  "challenge": { /* same as above */ },
                  "payload": {
                    "signature": "0x02f875…"
                  }
                }
              JSON
              ) %></code></pre>
            </figure>
            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">Encode this JSON as base64url (no padding, <code class="ic">-</code>/<code class="ic">_</code> instead of <code class="ic">+</code>/<code class="ic">/</code>) and send it:</p>
            <figure class="mt-4 overflow-hidden rounded-xl bg-mist-950 ring-1 ring-mist-900/10 dark:ring-white/10">
              <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:bash, <<~BASH
                curl -X POST https://podread.app/api/v1/mpp/narrations \\
                  -H "Content-Type: application/json" \\
                  -H "Authorization: Payment <base64url-encoded-credential>" \\
                  -d '{"source_type":"url","url":"https://www.worksinprogress.news/p/the-secret-behind-japans-railways"}'
              BASH
              ) %></code></pre>
            </figure>
            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">On success, the server returns <strong class="font-semibold text-mist-950 dark:text-white">201 Created</strong>:</p>
            <figure class="mt-4 overflow-hidden rounded-xl bg-mist-950 ring-1 ring-mist-900/10 dark:ring-white/10">
              <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:javascript, <<~JS
                { "id": "nar_aB3xK9mQ2pL7" }

                // Payment-Receipt header:
                // tx=0xabc123…, payment=mpp_…, sig=<hmac-hex>
              JS
              ) %></code></pre>
            </figure>
            <ul role="list" class="mt-4 space-y-1.5 text-mist-700 dark:text-mist-300">
              <li><code class="ic">id</code> is the created resource's public identifier. The prefix (<code class="ic">ep_</code> vs <code class="ic">nar_</code>) tells you whether this was an Episode (from <code class="ic">/api/v1/episodes</code> or <code class="ic">/api/v1/mpp/episodes</code>) or a Narration (from <code class="ic">/api/v1/mpp/narrations</code>).</li>
              <li><code class="ic">Payment-Receipt</code> is a comma-separated triplet: <code class="ic">tx</code> is the on-chain transaction hash, <code class="ic">payment</code> is the opaque MppPayment public id (useful for support inquiries), <code class="ic">sig</code> is an HMAC-SHA256 over the receipt body signed with the server's secret so clients can verify authenticity.</li>
            </ul>
            <aside class="mt-6 rounded-lg border-l-4 border-mist-400 bg-mist-50 p-4 text-sm text-mist-700 dark:border-mist-600 dark:bg-mist-900/50 dark:text-mist-300">
              <strong class="font-semibold text-mist-950 dark:text-white">Note:</strong>
              The <code class="rounded bg-mist-200/60 px-1.5 py-0.5 font-mono text-[0.9em] dark:bg-mist-800">mppx</code> CLI handles Steps 2 and 3 automatically. If you are building your own client, you must construct the credential yourself.
            </aside>
          </li>

          <li class="relative">
            <div class="flex items-baseline gap-x-4">
              <span class="font-mono text-xs text-mist-500 tabular-nums dark:text-mist-400">Step 4</span>
              <h3 class="font-serif text-xl text-mist-950 dark:text-white">Poll for status</h3>
            </div>
            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">Audio generation is asynchronous. Poll the narration endpoint:</p>
            <figure class="mt-4 overflow-hidden rounded-xl bg-mist-950 ring-1 ring-mist-900/10 dark:ring-white/10">
              <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:bash, <<~BASH
                curl https://podread.app/api/v1/mpp/narrations/nar_aB3xK9mQ2pL7
              BASH
              ) %></code></pre>
            </figure>
            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">Responses progress through <code class="ic">pending</code> → <code class="ic">preparing</code> → <code class="ic">processing</code> → <code class="ic">complete</code>.</p>
          </li>

          <li class="relative">
            <div class="flex items-baseline gap-x-4">
              <span class="font-mono text-xs text-mist-500 tabular-nums dark:text-mist-400">Step 5</span>
              <h3 class="font-serif text-xl text-mist-950 dark:text-white">Get audio</h3>
            </div>
            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">When status is <code class="ic">complete</code>, the response includes an <code class="ic">audio_url</code>:</p>
            <figure class="mt-4 overflow-hidden rounded-xl bg-mist-950 ring-1 ring-mist-900/10 dark:ring-white/10">
              <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-mist-100"><code class="highlight"><%= highlight(:json, <<~JSON
                {
                  "id": "nar_aB3xK9mQ2pL7",
                  "status": "complete",
                  "title": "Example Article",
                  "author": "Jane Doe",
                  "duration_seconds": 342,
                  "audio_url": "https://storage.googleapis.com/…/narrations/abc123.mp3"
                }
              JSON
              ) %></code></pre>
            </figure>
            <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">Narrations expire <strong class="font-semibold text-mist-950 dark:text-white">24 hours</strong> after creation. After expiration, <code class="ic">GET /api/v1/mpp/narrations/:id</code> returns 404. Episodes from <code class="ic">/api/v1/mpp/episodes</code> persist in the authenticated user's account and are retrieved via the Episodes API instead.</p>
          </li>
        </ol>
      </section>

      <!-- Authentication Paths -->
      <section id="auth-paths" class="scroll-mt-8 pt-20">
        <h2 class="font-serif text-3xl tracking-tight text-mist-950 dark:text-white">Authentication paths</h2>
        <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">There are three POST endpoints, one per intent. The endpoint you call determines what credentials the server demands and what resource it creates.</p>

        <div class="mt-8 grid gap-4 md:grid-cols-3">
          <!-- Path 1 -->
          <article class="relative rounded-xl bg-white p-6 ring-1 ring-mist-200 dark:bg-mist-900 dark:ring-white/10">
            <div class="font-mono text-xs text-mist-500 dark:text-mist-400">Path 1</div>
            <h3 class="mt-2 font-serif text-lg text-mist-950 dark:text-white">Credits</h3>
            <p class="mt-1 font-mono text-xs text-mist-500 dark:text-mist-400">POST /api/v1/episodes</p>
            <p class="mt-4 text-base sm:text-sm text-mist-700 dark:text-mist-300">Authenticated users with remaining credits. No MPP. Free-tier users who are out of credits get a 402 pointing at the billing upgrade URL — <strong class="font-semibold text-mist-950 dark:text-white">not</strong> an MPP challenge.</p>
            <div class="mt-5 rounded-md bg-mist-50 p-3 font-mono text-xs text-mist-700 dark:bg-mist-950 dark:text-mist-300">
              <div>Authorization:</div>
              <div class="pl-4">Bearer &lt;token&gt;</div>
            </div>
            <p class="mt-4 text-base sm:text-sm text-mist-500 dark:text-mist-400">Returns <code class="rounded bg-mist-100 px-1 py-0.5 font-mono text-[0.9em] text-mist-900 dark:bg-mist-800 dark:text-mist-100">{"id":"ep_…"}</code></p>
          </article>

          <!-- Path 2 -->
          <article class="relative rounded-xl bg-white p-6 ring-1 ring-mist-200 dark:bg-mist-900 dark:ring-white/10">
            <div class="font-mono text-xs text-mist-500 dark:text-mist-400">Path 2</div>
            <h3 class="mt-2 font-serif text-lg text-mist-950 dark:text-white">Anonymous MPP</h3>
            <p class="mt-1 font-mono text-xs text-mist-500 dark:text-mist-400">POST /api/v1/mpp/narrations</p>
            <p class="mt-4 text-base sm:text-sm text-mist-700 dark:text-mist-300">No account required. Pay per call via MPP. Creates a <strong class="font-semibold text-mist-950 dark:text-white">Narration</strong> — standalone audio, no user, 24h TTL, polled at <code class="ic">/api/v1/mpp/narrations/:id</code>.</p>
            <div class="mt-5 rounded-md bg-mist-50 p-3 font-mono text-xs text-mist-700 dark:bg-mist-950 dark:text-mist-300">
              <div>Authorization:</div>
              <div class="pl-4">Payment &lt;credential&gt;</div>
            </div>
            <p class="mt-4 text-base sm:text-sm text-mist-500 dark:text-mist-400">Returns <code class="rounded bg-mist-100 px-1 py-0.5 font-mono text-[0.9em] text-mist-900 dark:bg-mist-800 dark:text-mist-100">{"id":"nar_…"}</code></p>
          </article>

          <!-- Path 3 -->
          <article class="relative rounded-xl bg-white p-6 ring-1 ring-mist-200 dark:bg-mist-900 dark:ring-white/10">
            <div class="font-mono text-xs text-mist-500 dark:text-mist-400">Path 3</div>
            <h3 class="mt-2 font-serif text-lg text-mist-950 dark:text-white">Authenticated MPP</h3>
            <p class="mt-1 font-mono text-xs text-mist-500 dark:text-mist-400">POST /api/v1/mpp/episodes</p>
            <p class="mt-4 text-base sm:text-sm text-mist-700 dark:text-mist-300">Authenticated user who wants to pay per episode instead of subscribing. Creates an <strong class="font-semibold text-mist-950 dark:text-white">Episode</strong> attached to the user's primary podcast. Both credentials are required.</p>
            <div class="mt-5 rounded-md bg-mist-50 p-3 font-mono text-xs text-mist-700 dark:bg-mist-950 dark:text-mist-300">
              <div>Authorization:</div>
              <div class="pl-4">Bearer &lt;token&gt;,</div>
              <div class="pl-4">Payment &lt;credential&gt;</div>
            </div>
            <p class="mt-4 text-base sm:text-sm text-mist-500 dark:text-mist-400">Returns <code class="rounded bg-mist-100 px-1 py-0.5 font-mono text-[0.9em] text-mist-900 dark:bg-mist-800 dark:text-mist-100">{"id":"ep_…"}</code></p>
          </article>
        </div>

        <aside class="mt-8 rounded-lg border-l-4 border-mist-400 bg-mist-50 p-4 text-sm text-mist-700 dark:border-mist-600 dark:bg-mist-900/50 dark:text-mist-300">
          <strong class="font-semibold text-mist-950 dark:text-white">Path 3 header format.</strong>
          Send Bearer and Payment as <strong class="font-semibold text-mist-950 dark:text-white">a single <code class="rounded bg-mist-200/60 px-1.5 py-0.5 font-mono text-[0.9em] dark:bg-mist-800">Authorization</code> header</strong> with the two auth schemes comma-separated per <a href="https://www.rfc-editor.org/rfc/rfc9110.html#name-authorization" class="underline decoration-mist-300 underline-offset-4 hover:decoration-mist-700 dark:decoration-mist-700 dark:hover:decoration-mist-300">RFC 9110 §11.6.2</a> — <strong class="font-semibold text-mist-950 dark:text-white">not</strong> two separate <code class="rounded bg-mist-200/60 px-1.5 py-0.5 font-mono text-[0.9em] dark:bg-mist-800">Authorization</code> headers.
        </aside>
      </section>

      <!-- Request reference -->
      <section id="request-reference" class="scroll-mt-8 pt-20">
        <h2 class="font-serif text-3xl tracking-tight text-mist-950 dark:text-white">Request reference</h2>
        <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">Each of the three POST endpoints accepts the same source-and-metadata parameters. The differences are which <code class="ic">Authorization</code> scheme is required and whether the <code class="ic">voice</code> param is honored.</p>

        <%
          shared_source_rows = [
            ["source_type", "string", "Yes", %Q(One of <code class="font-mono text-[0.9em]">"url"</code>, <code class="font-mono text-[0.9em]">"text"</code>, <code class="font-mono text-[0.9em]">"extension"</code>).html_safe],
            ["url", "string", "For url/extension", "URL of the article"],
            ["text", "string", "For text", "Raw text to convert"],
            ["content", "string", "For extension", "HTML of the article body, typically Readability-extracted (not full page, not already-sanitized plain text). The server runs its own extractor and truncates the result to 20,000 characters before synthesis."],
            ["title", "string", "No", %Q(Episode title (defaults to <code class="font-mono text-[0.9em]">"Untitled"</code>)).html_safe],
            ["author", "string", "No", "Author name"],
            ["description", "string", "No", "Episode description"]
          ]
          param_cell_class = [
            "font-mono text-mist-900 dark:text-mist-100",
            "font-mono text-mist-500 dark:text-mist-400",
            "text-mist-700 dark:text-mist-300",
            "text-mist-700 dark:text-mist-300"
          ]
        %>

        <!-- POST /api/v1/episodes -->
        <h3 class="mt-10 font-mono text-base sm:text-sm text-mist-500 dark:text-mist-400">POST /api/v1/episodes</h3>
        <p class="mt-2 text-base sm:text-sm text-mist-700 dark:text-mist-300">Path 1 — Bearer-authenticated with credits. The <code class="ic">voice</code> param is ignored; Episodes use the user's stored voice preference.</p>

        <%= render "docs/responsive_table",
          headers: ["Parameter", "Type", "Required", "Description"],
          rows: shared_source_rows,
          cell_class: param_cell_class
        %>

        <!-- POST /api/v1/mpp/narrations -->
        <h3 class="mt-12 font-mono text-base sm:text-sm text-mist-500 dark:text-mist-400">POST /api/v1/mpp/narrations</h3>
        <p class="mt-2 text-base sm:text-sm text-mist-700 dark:text-mist-300">Path 2 — anonymous, Payment credential only. The <code class="ic">voice</code> param selects which voice (and therefore which tier price) the 402 challenge quotes.</p>

        <%= render "docs/responsive_table",
          headers: ["Parameter", "Type", "Required", "Description"],
          rows: shared_source_rows + [
            ["voice", "string", "No", %Q(Voice catalog key. Defaults to <code class="font-mono text-[0.9em]">"felix"</code> (Standard, 75¢). See <a href="#voices" class="underline decoration-mist-300 underline-offset-4 hover:decoration-mist-700 dark:decoration-mist-700 dark:hover:decoration-mist-300">Voices</a>.).html_safe]
          ],
          cell_class: param_cell_class
        %>

        <!-- POST /api/v1/mpp/episodes -->
        <h3 class="mt-12 font-mono text-base sm:text-sm text-mist-500 dark:text-mist-400">POST /api/v1/mpp/episodes</h3>
        <p class="mt-2 text-base sm:text-sm text-mist-700 dark:text-mist-300">Path 3 — Bearer + Payment. An explicit <code class="ic">voice</code> param wins; otherwise the user's saved preference is used, falling back to the catalog default (<code class="ic">felix</code>, Standard).</p>

        <%= render "docs/responsive_table",
          headers: ["Parameter", "Type", "Required", "Description"],
          rows: shared_source_rows + [
            ["voice", "string", "No", %Q(Voice catalog key. Overrides the user's stored voice preference for this request only. See <a href="#voices" class="underline decoration-mist-300 underline-offset-4 hover:decoration-mist-700 dark:decoration-mist-700 dark:hover:decoration-mist-300">Voices</a>.).html_safe]
          ],
          cell_class: param_cell_class
        %>
      </section>

      <!-- Voices -->
      <section id="voices" class="scroll-mt-8 pt-20">
        <h2 class="font-serif text-3xl tracking-tight text-mist-950 dark:text-white">Voices</h2>
        <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">MPP callers may select a voice by passing a <code class="ic">voice</code> catalog key. All catalog voices are available on the MPP paths. Voice tier determines price: Standard voices cost 75¢, Premium voices cost $1.50. The default when <code class="ic">voice</code> is omitted is <code class="ic">felix</code> (British male, Standard, 75¢). Invalid keys return <strong class="font-semibold text-mist-950 dark:text-white">422</strong>.</p>
        <p class="mt-2 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">Voice resolution on MPP endpoints follows a three-step hierarchy: explicit <code class="ic">voice</code> param → user's saved preference (authenticated only) → catalog default (<code class="ic">felix</code>).</p>

        <div class="-mx-6 -my-2 mt-6 overflow-x-auto whitespace-nowrap lg:-mx-10">
          <div class="inline-block min-w-full px-6 py-2 align-middle lg:px-10">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-mist-300 dark:border-mist-700">
                  <th class="whitespace-nowrap py-3 pr-6 text-left font-medium text-mist-950 dark:text-white">Key</th>
                  <th class="whitespace-nowrap py-3 pr-6 text-left font-medium text-mist-950 dark:text-white">Name</th>
                  <th class="whitespace-nowrap py-3 pr-6 text-left font-medium text-mist-950 dark:text-white">Accent</th>
                  <th class="whitespace-nowrap py-3 pr-6 text-left font-medium text-mist-950 dark:text-white">Gender</th>
                  <th class="whitespace-nowrap py-3 pr-6 text-left font-medium text-mist-950 dark:text-white">Tier</th>
                  <th class="whitespace-nowrap py-3 text-left font-medium text-mist-950 dark:text-white"><span class="sr-only">Default</span></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-mist-200 dark:divide-mist-800">
                <% [
                  ["wren",   "Wren",   "British",  "Female", "Standard", false],
                  ["felix",  "Felix",  "British",  "Male",   "Standard", true],
                  ["sloane", "Sloane", "American", "Female", "Standard", false],
                  ["archer", "Archer", "American", "Male",   "Standard", false],
                  ["gemma",  "Gemma",  "British",  "Female", "Standard", false],
                  ["hugo",   "Hugo",   "British",  "Male",   "Standard", false],
                  ["quinn",  "Quinn",  "American", "Female", "Standard", false],
                  ["theo",   "Theo",   "American", "Male",   "Standard", false],
                  ["elara",  "Elara",  "British",  "Female", "Premium",  false],
                  ["callum", "Callum", "British",  "Male",   "Premium",  false],
                  ["lark",   "Lark",   "American", "Female", "Premium",  false],
                  ["nash",   "Nash",   "American", "Male",   "Premium",  false]
                ].each do |key, name, accent, gender, tier, is_default| %>
                  <tr>
                    <td class="py-3 pr-6 font-mono text-mist-900 dark:text-mist-100"><%= key %></td>
                    <td class="py-3 pr-6 text-mist-700 dark:text-mist-300"><%= name %></td>
                    <td class="py-3 pr-6 text-mist-700 dark:text-mist-300"><%= accent %></td>
                    <td class="py-3 pr-6 text-mist-700 dark:text-mist-300"><%= gender %></td>
                    <td class="py-3 pr-6">
                      <% if tier == "Premium" %>
                        <span class="inline-flex items-center rounded-full bg-mist-900 px-2.5 py-0.5 text-xs font-medium text-white dark:bg-mist-100 dark:text-mist-900">Premium</span>
                      <% else %>
                        <span class="inline-flex items-center rounded-full bg-mist-100 px-2.5 py-0.5 text-xs font-medium text-mist-700 dark:bg-mist-800 dark:text-mist-300">Standard</span>
                      <% end %>
                    </td>
                    <td class="py-3 text-mist-500 dark:text-mist-400" aria-label="<%= "Default voice" if is_default %>"><%= "★" if is_default %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
        <p class="mt-4 text-sm sm:text-xs text-mist-500 dark:text-mist-400">★ default when <code class="font-mono text-[0.9em]">voice</code> is omitted</p>

        <aside class="mt-8 rounded-lg border-l-4 border-mist-400 bg-mist-50 p-4 text-sm text-mist-700 dark:border-mist-600 dark:bg-mist-900/50 dark:text-mist-300">
          <strong class="font-semibold text-mist-950 dark:text-white">Where <code class="rounded bg-mist-200/60 px-1.5 py-0.5 font-mono text-[0.9em] dark:bg-mist-800">voice</code> is honored.</strong>
          The <code class="rounded bg-mist-200/60 px-1.5 py-0.5 font-mono text-[0.9em] dark:bg-mist-800">voice</code> param is read on both MPP endpoints (<code class="rounded bg-mist-200/60 px-1.5 py-0.5 font-mono text-[0.9em] dark:bg-mist-800">/mpp/narrations</code> and <code class="rounded bg-mist-200/60 px-1.5 py-0.5 font-mono text-[0.9em] dark:bg-mist-800">/mpp/episodes</code>). It is <strong class="font-semibold text-mist-950 dark:text-white">not</strong> read on the credits endpoint <code class="rounded bg-mist-200/60 px-1.5 py-0.5 font-mono text-[0.9em] dark:bg-mist-800">/api/v1/episodes</code> — there, Episodes use the user's stored voice preference.
        </aside>
      </section>

      <!-- Pricing -->
      <section id="pricing" class="scroll-mt-8 pt-20">
        <h2 class="font-serif text-3xl tracking-tight text-mist-950 dark:text-white">Pricing</h2>
        <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
          MPP pricing is tiered by voice. The resolved voice's tier determines the challenge amount issued in the 402 response.
        </p>

        <%= render "docs/responsive_table",
          headers: ["Tier", "Price (USD)", "Base units (6 decimals)", "Voices"],
          rows: [
            ["Standard", "$0.75", "750,000", "wren, felix, sloane, archer, gemma, hugo, quinn, theo"],
            ["Premium",  "$1.50", "1,500,000", "elara, callum, lark, nash"]
          ],
          cell_class: [
            "text-mist-900 dark:text-mist-100",
            "font-serif text-mist-950 tabular-nums dark:text-white",
            "font-mono tabular-nums text-mist-700 dark:text-mist-300",
            "font-mono text-mist-700 dark:text-mist-300"
          ]
        %>

        <p class="mt-6 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
          The default voice when <code class="ic">voice</code> is omitted is <code class="ic">felix</code> (Standard), so the cheapest successful call costs $0.75. Requesting a Premium voice shifts the entire 402 → pay → retry flow to $1.50.
        </p>

        <dl class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div class="rounded-lg bg-white p-4 ring-1 ring-mist-200 dark:bg-mist-900 dark:ring-white/10">
            <dt class="text-xs font-medium text-mist-500 dark:text-mist-400">Token (podread.app)</dt>
            <dd class="mt-1 break-all font-mono text-sm text-mist-900 dark:text-mist-100">USDC.e · 0x20c0…b9537d11c60e8b50</dd>
          </div>
          <div class="rounded-lg bg-white p-4 ring-1 ring-mist-200 dark:bg-mist-900 dark:ring-white/10">
            <dt class="text-xs font-medium text-mist-500 dark:text-mist-400">Decimals</dt>
            <dd class="mt-1 font-mono text-sm text-mist-900 tabular-nums dark:text-mist-100">6 (1 USD = 1,000,000)</dd>
          </div>
          <div class="rounded-lg bg-white p-4 ring-1 ring-mist-200 dark:bg-mist-900 dark:ring-white/10">
            <dt class="text-xs font-medium text-mist-500 dark:text-mist-400">RPC</dt>
            <dd class="mt-1 break-all font-mono text-sm text-mist-900 dark:text-mist-100">rpc.moderato.tempo.xyz</dd>
          </div>
        </dl>
        <p class="mt-4 max-w-[65ch] text-pretty text-sm text-mist-500 dark:text-mist-400">
          On <strong class="font-semibold text-mist-700 dark:text-mist-300">podread.app</strong>, payments are settled in <strong class="font-semibold text-mist-700 dark:text-mist-300">USDC.e</strong> — USDC bridged to Tempo via <a href="https://stargate.finance/" class="underline decoration-mist-300 underline-offset-4 hover:decoration-mist-700 dark:decoration-mist-700 dark:hover:decoration-mist-300">Stargate</a>. It is not Circle-native USDC; token balances held on Tempo are bridge-wrapped and must be unwrapped via Stargate to redeem on other chains. Self-hosted deployments targeting Tempo's Moderato testnet can use the predeployed <strong class="font-semibold text-mist-700 dark:text-mist-300">pathUSD</strong> stablecoin (<code class="ic">0x20c0…0000</code>) instead — the faucet dispenses pathUSD, not USDC.e. The <code class="ic">request.currency</code> field in every 402 challenge echoes whichever contract the server is configured for, so clients should read it rather than hardcode either address.
        </p>
        <p class="mt-6 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">
          The <code class="ic">amount</code> in the 402 response body is in <strong class="font-semibold text-mist-950 dark:text-white">cents</strong> (75 = $0.75, 150 = $1.50). The <code class="ic">amount</code> in the <code class="ic">WWW-Authenticate</code> header's <code class="ic">request</code> field is in <strong class="font-semibold text-mist-950 dark:text-white">token base units</strong> (750,000 for Standard, 1,500,000 for Premium).
        </p>
        <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">A challenge is bound to a specific voice tier by an HMAC-signed request blob. A Standard-priced credential cannot be redeemed against a Premium voice (or vice versa) — the server re-issues a fresh 402 at the correct price when the tiers don't match. If narration processing fails after payment succeeds, the payment is automatically refunded.</p>
      </section>

      <!-- Rate Limits -->
      <section id="rate-limits" class="scroll-mt-8 pt-20">
        <h2 class="font-serif text-3xl tracking-tight text-mist-950 dark:text-white">Rate limits</h2>

        <%= render "docs/responsive_table",
          headers: ["Endpoint", "Limit", "Window", "Key"],
          rows: [
            ["POST /api/v1/episodes", "20", "1 hour", "Bearer token"],
            ["POST /api/v1/mpp/narrations", "10", "1 minute", "IP address"],
            ["GET /api/v1/mpp/narrations/:id", "60", "1 minute", "IP address"]
          ],
          cell_class: [
            "font-mono text-mist-900 dark:text-mist-100",
            "tabular-nums text-mist-700 dark:text-mist-300",
            "text-mist-700 dark:text-mist-300",
            "text-mist-700 dark:text-mist-300"
          ]
        %>
        <p class="mt-4 max-w-[65ch] text-base sm:text-sm text-mist-500 dark:text-mist-400">Throttled requests return <strong class="font-semibold text-mist-700 dark:text-mist-300">429 Too Many Requests</strong> with a <code class="ic">Retry-After</code> header.</p>
        <p class="mt-4 max-w-[65ch] text-pretty text-base sm:text-sm text-mist-500 dark:text-mist-400"><code class="ic">POST /api/v1/mpp/episodes</code> has no rack-level throttle at this time — the endpoint is Bearer-gated and payment-gated, so cost is the self-limit. A per-user throttle is on the roadmap.</p>
        <p class="mt-4 max-w-[65ch] text-pretty text-base sm:text-sm text-mist-500 dark:text-mist-400">The anonymous MPP create limit (10/minute per IP) exists to block abusers who churn through the 402-challenge flow without paying — every challenge costs a Stripe PaymentIntent and a pending DB row. A legitimate client making one paid narration burns at most 2 requests (initial 402, retry with credential), so 10/min leaves 5× headroom.</p>
      </section>

      <!-- Error Codes -->
      <section id="errors" class="scroll-mt-8 pt-20">
        <h2 class="font-serif text-3xl tracking-tight text-mist-950 dark:text-white">Error codes</h2>

        <aside class="mt-6 rounded-lg border-l-4 border-mist-400 bg-mist-50 p-4 text-sm text-mist-700 dark:border-mist-600 dark:bg-mist-900/50 dark:text-mist-300">
          <strong class="font-semibold text-mist-950 dark:text-white">Two flavors of 402:</strong>
          <ul role="list" class="mt-2 space-y-1.5">
            <li><strong class="font-semibold">MPP challenge</strong> (from <code class="ic">/api/v1/mpp/*</code>): includes a <code class="ic">WWW-Authenticate: Payment</code> header and a <code class="ic">challenge</code> object in the body. Retry with a Payment credential. Issued when no credential was sent, the credential failed verification, or the credential's tier didn't match the resolved voice.</li>
            <li><strong class="font-semibold">Upgrade prompt</strong> (from <code class="ic">/api/v1/episodes</code>): <strong>no</strong> <code class="ic">WWW-Authenticate</code> header. Body is <code class="ic">{"error","credits_remaining","upgrade_url"}</code>. The authenticated user is out of credits — direct them to billing or to the <code class="ic">/api/v1/mpp/episodes</code> endpoint.</li>
          </ul>
        </aside>

        <%= render "docs/responsive_table",
          headers: ["Status", "Meaning", "When"],
          rows: [
            ["201", "Created", "Episode or narration created successfully"],
            ["400", "Bad Request", "Malformed JSON body or missing required headers"],
            ["401", "Unauthorized", "Bearer token is invalid, expired, or revoked"],
            ["402", "Payment Required", "See the callout above — either an MPP challenge or an upgrade prompt".html_safe],
            ["403", "Forbidden", "Authenticated user exists but lacks permission for the requested action"],
            ["404", "Not Found", 'Narration (<code class="ic">GET /api/v1/mpp/narrations/:id</code>) does not exist or has expired past its 24h TTL'.html_safe],
            ["422", "Unprocessable Entity", 'Invalid or missing <code class="ic">source_type</code>, invalid <code class="ic">voice</code>, or content error'.html_safe],
            ["429", "Too Many Requests", 'Rate limit exceeded (see <a href="#rate-limits" class="underline decoration-mist-300 underline-offset-4 hover:decoration-mist-700 dark:decoration-mist-700 dark:hover:decoration-mist-300">Rate limits</a>); includes a <code class="ic">Retry-After</code> header'.html_safe],
            ["500", "Internal Server Error", "Unexpected server failure (not caused by any of the above)"],
            ["503", "Service Unavailable", "Stripe failed to provision a deposit address, or Tempo RPC is unreachable"]
          ],
          cell_class: [
            "font-mono tabular-nums text-mist-900 dark:text-mist-100",
            "text-mist-700 dark:text-mist-300",
            "text-mist-700 dark:text-mist-300"
          ]
        %>
      </section>

      <!-- Environment / Configuration -->
      <section id="config" class="scroll-mt-8 pt-20">
        <h2 class="font-serif text-3xl tracking-tight text-mist-950 dark:text-white">Environment</h2>
        <p class="mt-4 max-w-[65ch] text-pretty text-mist-700 dark:text-mist-300">For self-hosting, the following environment variables configure MPP. Stripe must also be configured (standard <code class="ic">STRIPE_SECRET_KEY</code> etc.) since deposit addresses are provisioned via Stripe's crypto PaymentIntent API.</p>

        <%= render "docs/responsive_table",
          headers: ["Variable", "Default", "Description"],
          rows: [
            ["MPP_SECRET_KEY", "random hex", "HMAC key for signing challenges and receipts. Must be stable across deploys."],
            ["MPP_PRICE_STANDARD_CENTS", "75", "Price for a Standard-voice narration, in USD cents"],
            ["MPP_PRICE_PREMIUM_CENTS", "150", "Price for a Premium-voice narration, in USD cents"],
            ["MPP_CURRENCY", "usd", "Currency code"],
            ["MPP_CHALLENGE_TTL_SECONDS", "300", "How long a 402 challenge is valid"],
            ["MPP_STRIPE_API_VERSION", "2026-03-04.preview", "Stripe API version pinned to MPP preview channel"],
            ["TEMPO_RPC_URL", "rpc.moderato.tempo.xyz", "Tempo JSON-RPC endpoint"],
            ["TEMPO_CURRENCY_TOKEN", "0x20c0…0000", %Q(Stablecoin contract on Tempo. Default is pathUSD (testnet faucet-dispensable). <strong class="font-semibold text-mist-700 dark:text-mist-300">podread.app</strong> overrides this to USDC.e at <code class="font-mono text-[0.9em]">0x20c0…b9537d11c60e8b50</code>.).html_safe],
            ["TEMPO_TOKEN_DECIMALS", "6", "Decimal places for the stablecoin (both pathUSD and USDC.e are 6)"],
            ["TEMPO_RPC_OPEN_TIMEOUT_SECONDS", "5", "TCP connect timeout"],
            ["TEMPO_RPC_READ_TIMEOUT_SECONDS", "10", "Read timeout"],
            ["APP_HOST", "localhost:3000", "Used as the realm in challenges"]
          ],
          cell_class: [
            "font-mono text-mist-900 dark:text-mist-100",
            "font-mono text-mist-500 dark:text-mist-400",
            "text-mist-700 dark:text-mist-300"
          ]
        %>
      </section>
    </div>

    <!-- Right-rail TOC -->
    <nav aria-label="On this page" class="hidden xl:block">
      <div class="sticky top-24 py-8">
        <div class="font-mono text-xs text-mist-500 dark:text-mist-400">On this page</div>
        <ul role="list" class="mt-4 space-y-2.5 border-l border-mist-200 dark:border-mist-800">
          <% [
            ["#quickstart", "Quick start"],
            ["#protocol", "Protocol flow"],
            ["#auth-paths", "Authentication paths"],
            ["#request-reference", "Request reference"],
