<div class="mx-auto max-w-md px-4 py-12">
  <div class="rounded-xl border border-mist-200 bg-white p-8 shadow-sm dark:border-mist-700 dark:bg-mist-800">
    <h1 class="text-2xl font-semibold text-mist-950 dark:text-white">Welcome back</h1>
    <% if (user = soft_deleted_current_user) %>
      <p class="mt-3 text-sm/6 text-mist-500 dark:text-mist-400">
        Your PodRead account was deleted
        <time datetime="<%= user.deleted_at.iso8601 %>"
              title="<%= user.deleted_at.strftime("%B %-d, %Y at %-I:%M %p") %>"
              class="underline decoration-dotted decoration-mist-400 dark:decoration-mist-600 underline-offset-2">
          <%= time_ago_in_words(user.deleted_at) %> ago</time>.
        Restore it to keep using PodRead.
      </p>
    <% end %>

    <div class="mt-6 flex flex-col gap-3 sm:flex-row">
      <%= button_to "Restore account", restore_account_path,
            method: :post,
            class: button_classes(type: :primary) %>
      <%= button_to "Sign out", session_path,
            method: :delete,
            class: button_classes(type: :secondary) %>
    </div>

    <p class="mt-4 text-xs/5 text-mist-500 dark:text-mist-400">
      Note: any prior paid subscription was cancelled when you deleted your account. You can resubscribe from Billing after restoring.
    </p>
  </div>
</div>
